#!/bin/ash

[ -c /dev/console ] || mknod -m 600 /dev/console c 5 1
exec >/dev/console 2>&1

echo "RetroPangUI initramfs v0.6"

panic() {
    echo "!!! INITRAMFS PANIC: $1"
    while true; do sleep 60; done
}

# ─── [1/7] 기본 마운트 ───────────────────────────────────────────
echo ">>> [1/7] proc/sys/dev 마운트"
mount -t proc none /proc     && echo "  proc OK" || { echo "  proc FAIL"; panic "proc 마운트 실패"; }
mount -t sysfs none /sys     && echo "  sys OK"  || { echo "  sys FAIL";  panic "sys 마운트 실패"; }
mount -t devtmpfs none /dev  && echo "  devtmpfs OK" || {
    echo "  devtmpfs 실패 — mdev 사용"
    echo /bin/mdev > /proc/sys/kernel/hotplug 2>/dev/null
    mdev -s && echo "  mdev OK" || echo "  mdev FAIL"
}
mdev -s 2>/dev/null

# ─── [2/7] boot 파티션 탐색 (FAT32, p1) ─────────────────────────
# /boot 로 마운트: loop 디바이스 경로가 switch_root 후에도 /boot/... 로 유효함.
# /boot_root 같은 임시 이름을 쓰면 switch_root 후 경로가 소멸해 loop0 고아(orphan)
# 상태가 되고, 종료 시 umount -a가 loop/boot 를 정리 못해 reboot이 깨진다.
echo ">>> [2/7] boot 파티션 탐색 (최대 30초)..."
mkdir -p /boot
BOOT_DEV=""
i=0
while [ $i -lt 30 ]; do
    i=$((i+1))
    mdev -s 2>/dev/null
    for DEV in /dev/mmcblk0p1 /dev/mmcblk1p1 /dev/mmcblk2p1 /dev/mmcblk3p1; do
        [ -b "$DEV" ] || continue
        if mount -t vfat -o rw "$DEV" /boot; then
            if [ -f /boot/retropangui.squashfs ]; then
                BOOT_DEV="$DEV"
                echo "  → boot: $DEV"
                break 2
            fi
            echo "  $DEV: squashfs 없음, 건너뜀"
            umount /boot 2>/dev/null
        fi
    done
    [ $((i % 5)) -eq 0 ] && echo "  대기 중... ${i}s"
    sleep 1
done

if [ -z "$BOOT_DEV" ]; then
    echo "!!! 최종 블록 장치 목록:"
    ls -la /dev/mmcblk* 2>/dev/null || echo "  없음"
    panic "boot 파티션 마운트 실패 (30초 대기 후)"
fi

OTA_APPLIED=0

# ─── share 파티션(p3) 초기 생성 ──────────────────────────────────
DISK="${BOOT_DEV%p1}"
DB="${DISK##*/}"

if ! grep -q "${DB}p3" /proc/partitions 2>/dev/null; then
    if [ -f /boot/.p3-creating ]; then
        echo "  p3 fdisk 후에도 미인식 — 건너뜀"
        rm -f /boot/.p3-creating
        sync
    else
        P3_START=$(fdisk -l "${DISK}" 2>/dev/null | awk -v p="${DISK}p2" '$1==p {print $5+1; exit}')
        if [ -n "$P3_START" ]; then
            touch /boot/.p3-creating && sync
            printf "n\np\n3\n%s\n\nw\n" "${P3_START}" | fdisk "${DISK}" >/dev/null 2>&1
            sync; sync
            echo ""
            echo "======================================"
            echo "  SD 카드 초기 설정 완료 — 재부팅합니다."
            echo "======================================"
            sleep 3
            reboot -f
        else
            echo "  p3 생성 실패: fdisk -l 파싱 불가"
        fi
    fi
else
    echo "  p3 이미 있음"
fi

# ─── [3/7] OTA 확인 ──────────────────────────────────────────────
echo ">>> [3/7] OTA 확인..."
UPDATE_FILE=""
[ -f /boot/update/retropangui.update ] && UPDATE_FILE=/boot/update/retropangui.update
if [ -n "$UPDATE_FILE" ]; then
    SHA256_FILE="${UPDATE_FILE}.sha256"
    VALID=0
    if [ -f "$SHA256_FILE" ]; then
        EXPECTED=$(awk '{print $1}' "$SHA256_FILE")
        ACTUAL=$(sha256sum "$UPDATE_FILE" | awk '{print $1}')
        [ "$EXPECTED" = "$ACTUAL" ] && VALID=1
    fi
    if [ "$VALID" = "1" ]; then
        echo "    OTA 적용 중: $(basename $UPDATE_FILE)"
        cp /boot/retropangui.squashfs /boot/retropangui.squashfs.old 2>/dev/null || true
        mv "$UPDATE_FILE" /boot/retropangui.squashfs
        rm -f "$SHA256_FILE"
        if [ -f /boot/update/initramfs.update.cpio.gz ]; then
            echo "    initramfs 업데이트 중..."
            cp /boot/initramfs.cpio.gz /boot/initramfs.cpio.gz.old 2>/dev/null || true
            mv /boot/update/initramfs.update.cpio.gz /boot/initramfs.cpio.gz
            echo "    initramfs 업데이트 완료 (다음 부팅 시 적용)"
        fi
        sync
        OTA_APPLIED=1
        echo "    OTA 완료"
    else
        echo "    OTA 검증 실패 — 기존 squashfs 사용"
        rm -rf /boot/update/ 2>/dev/null
        sync
    fi
fi

# ─── [4/7] squashfs 마운트 ───────────────────────────────────────
# /squashfs 로 마운트 후 /merged/squashfs 로 이동:
# switch_root 후 /squashfs 가 /proc/mounts 에 보여야
# 종료 시 umount -a 가 squashfs → loop0 → /boot 순서로 정리할 수 있다.
echo ">>> [4/7] squashfs 마운트..."
mkdir -p /squashfs
if mount -t squashfs -o loop /boot/retropangui.squashfs /squashfs; then
    echo "  squashfs OK"
else
    echo "  squashfs 실패 — .old 롤백 시도..."
    mount -t squashfs -o loop /boot/retropangui.squashfs.old /squashfs \
        && echo "  .old 롤백 성공" \
        || panic "squashfs 마운트 실패 (현재 + .old 모두)"
fi

# ─── [5/7] overlay ext4 마운트 ──────────────────────────────────
echo ">>> [5/7] overlay ext4 마운트..."
OVERLAY_DEV="${BOOT_DEV%p1}p2"
mkdir -p /overlay
mount -t ext4 "$OVERLAY_DEV" /overlay || panic "overlay 마운트 실패: $OVERLAY_DEV"
echo "  overlay OK: $OVERLAY_DEV"
mkdir -p /overlay/upper /overlay/work

# OTA 적용 시: upper 레이어의 시스템 스크립트 정리
# upper에 남은 구버전 init.d 파일이 새 squashfs 버전을 가리는 것을 방지
if [ "$OTA_APPLIED" = "1" ]; then
    echo "  OTA: upper/etc/init.d 정리 중..."
    rm -rf /overlay/upper/etc/init.d
fi

# 공장 초기화 플래그 확인
if [ -f /boot/.factory-reset ]; then
    echo "  공장 초기화: upper 레이어 전체 삭제 중..."
    rm -rf /overlay/upper
    mkdir -p /overlay/upper /overlay/work

    # retropangui-boot.conf는 /boot(FAT32, p1)에 있어 upper 삭제로는 안
    # 지워짐 - sharenetwork_*/sharewait(NAS 계정정보 포함 가능)는 남아있으면
    # 안 되는 사용자 데이터라 여기서 별도로 제거. sharedevice=는 물리적
    # 저장장치 배선 설정이라 건드리지 않음(2026-07-16, 실기기에서 공장
    # 초기화 후에도 NFS 마운트가 계속 살아있는 현상 발견 후 수정).
    if [ -f /boot/retropangui-boot.conf ]; then
        sed -i '/^sharenetwork_/d; /^sharewait=/d' /boot/retropangui-boot.conf
    fi

    # share/system(retropangui.conf, es_settings.cfg, es_input.cfg, retroarch.cfg
    # 등)은 exFAT share 파티션(p3)에 있어 여기(initramfs)에서 마운트/삭제할 수
    # 없음(exfat 도구 미탑재, share는 S61share가 switch_root 이후 마운트).
    # ES의 공장 초기화 확인 문구("THIS WILL RESET SYSTEM SETTINGS")가 실제로
    # 지워야 하는 대상이라 마커만 남겨두고 S61share가 share 마운트 직후 처리.
    touch /overlay/upper/.factory-reset-pending-share

    rm -f /boot/.factory-reset
    sync
    echo "  공장 초기화 완료"
fi

# ─── [6/7] overlayfs ─────────────────────────────────────────────
echo ">>> [6/7] overlayfs..."
mkdir -p /merged
mount -t overlay overlay \
    -o lowerdir=/squashfs,upperdir=/overlay/upper,workdir=/overlay/work \
    /merged || panic "overlayfs 마운트 실패"
echo "  overlayfs OK"

if [ "$OTA_APPLIED" = "1" ]; then
    NEW_VER=$(cat /merged/etc/retropangui-version 2>/dev/null || echo "unknown")
    echo "$NEW_VER" > /merged/etc/.ota-changelog-pending 2>/dev/null || true
fi

# ─── [7/7] switch_root ───────────────────────────────────────────
echo ">>> [7/7] switch_root..."
sync; sync

# squashfs를 /merged/squashfs 로 이동 → switch_root 후 /squashfs 로 접근 가능
mkdir -p /merged/squashfs
mount --move /squashfs /merged/squashfs

mkdir -p /merged/proc /merged/sys /merged/dev /merged/boot /merged/overlay
mount --move /proc    /merged/proc
mount --move /sys     /merged/sys
mount --move /dev     /merged/dev
mount --move /boot    /merged/boot
mount --move /overlay /merged/overlay

exec switch_root /merged /sbin/init
panic "switch_root 실패"
