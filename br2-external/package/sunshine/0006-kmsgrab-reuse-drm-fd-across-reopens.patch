+    // RetroPangUI 2026-07-16: Amlogic 벤더 DRM 드라이버가 같은 프로세스 안에서
+    // /dev/dri/cardN을 close() 후 재차 open()하면(Sunshine이 인코더를 하나씩
+    // 시도할 때마다 반복함) 그 뒤로 열리는 fd에서는 원래 정상이던 plane의
+    // fb_id를 0으로 돌려줌(다른 프로세스나 최초 open에서는 항상 정상) - 실기기
+    // LD_PRELOAD 인터포저로 확인(todo-20260709-remote-streaming.html). 커널
+    // 드라이버 자체를 고칠 수 없으니, 같은 경로는 프로세스 생애주기 동안 딱
+    // 한 번만 진짜 open()하고 이후엔 그 fd를 dup()해서 재사용 - dup된 fd는
+    // 커널 안에서 같은 open file description(=같은 DRM 클라이언트 세션)을
+    // 공유하므로 close/reopen 사이클 자체가 사라짐.
+    inline int open_or_reuse_card_fd(const char *path) {
+      static std::mutex mtx;
+      static std::unordered_map<std::string, int> master_fds;
+
+      std::lock_guard<std::mutex> lock(mtx);
+      auto it = master_fds.find(path);
+      if (it != master_fds.end()) {
+        return dup(it->second);
+      }
+
+      int master = open(path, O_RDWR);
+      if (master < 0) {
+        return -1;
+      }
+
+      master_fds.emplace(path, master);
+      return dup(master);
+    }
+
