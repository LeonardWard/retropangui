+++ b/src/vaapi_stub.cpp
@@ -0,0 +1,21 @@
+/**
+ * @file src/vaapi_stub.cpp
+ * @brief Stub for vaMapBuffer2, absent from this build's libva (2.20.0).
+ *
+ * ffmpeg's prebuilt libavutil.a (hwcontext_vaapi.o) references
+ * vaMapBuffer2 unconditionally, even though this build has
+ * SUNSHINE_ENABLE_VAAPI=OFF and never actually creates a VAAPI
+ * hwcontext. This stub only exists to satisfy the linker; it is
+ * never reachable at runtime.
+ */
+#include <va/va.h>
+
+extern "C" VAStatus vaMapBuffer2(VADisplay dpy, VABufferID buf_id, void **pbuf, uint32_t flags) {
+  (void) dpy;
+  (void) buf_id;
+  (void) flags;
+  if (pbuf) {
+    *pbuf = nullptr;
+  }
+  return VA_STATUS_ERROR_UNIMPLEMENTED;
+}
