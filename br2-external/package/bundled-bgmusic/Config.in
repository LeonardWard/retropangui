config BR2_PACKAGE_BUNDLED_BGMUSIC
	bool "bundled-bgmusic"
	help
	  Bundled background music (MIDI files).
	  MIDI files are copied to /share/bios/music/ on first boot.
	  Requires BR2_PACKAGE_FLUID_SOUNDFONT for playback (VLC
	  fluidsynth plugin in EmulationStation uses FluidR3_GM.sf2,
	  MIT license, installed to /usr/share/soundfonts/).
