config BR2_PACKAGE_RPUI_BT
	bool "rpui-bt"
	select BR2_PACKAGE_BLUEZ5_UTILS
	select BR2_PACKAGE_BLUEZ5_UTILS_CLIENT
	select BR2_PACKAGE_LIBGLIB2
	help
	  RetroPangUI 블루투스 관리 데몬.
	  USB BT 동글 핫플러그 감지, /var/lib/bluetooth를 share 파티션으로
	  영속화, BlueZ D-Bus API(GDBus)에 직접 붙어 에이전트 등록·어댑터
	  제어·페어링(InterfacesAdded/PropertiesChanged 이벤트 기반)을
	  담당한다. list/live_devices/remove는 bluetoothctl 조회를 그대로 씀.
