# 외부 저장장치(USB/SD카드) 파티션 삽입 감지
# 내부 eMMC(mmcblk0) 제외, 파티션 단위 감지
# DEVTYPE 미지원 환경 대응: /sys/class/block/%k/partition 존재 여부로 파티션 판별
# ES가 /tmp/retropangui-new-storage 파일을 읽어 GUI 팝업 표시

ACTION=="add", SUBSYSTEM=="block", KERNEL!="mmcblk0*", KERNEL!="loop*", KERNEL!="ram*", \
    RUN+="/bin/sh -c 'test -f /sys/class/block/%k/partition && echo %k >> /tmp/retropangui-new-storage || true'"

ACTION=="remove", SUBSYSTEM=="block", KERNEL!="mmcblk0*", KERNEL!="loop*", KERNEL!="ram*", \
    RUN+="/bin/sh -c 'sed -i \"/^%k$/d\" /tmp/retropangui-new-storage 2>/dev/null || true'"
