# 99-gamepad.rules — 게임패드 장치 권한 설정
#
# /dev/input/js*, /dev/input/event* 에 대해 root 외 프로세스(ES, RetroArch)가
# 읽을 수 있도록 퍼미션을 설정한다.
# Buildroot 기본 환경에는 "input" 그룹이 없으므로 MODE=0664로 단순화.

# ── 모든 조이스틱 장치 ──────────────────────────────────────────
SUBSYSTEM=="input", KERNEL=="js[0-9]*",    MODE="0664"

# ── 컨트롤러 이름 패턴을 가진 이벤트 장치 ──────────────────────
SUBSYSTEM=="input", KERNEL=="event[0-9]*", \
    ATTRS{name}=="*Controller*",           MODE="0664"
SUBSYSTEM=="input", KERNEL=="event[0-9]*", \
    ATTRS{name}=="*Joystick*",             MODE="0664"
SUBSYSTEM=="input", KERNEL=="event[0-9]*", \
    ATTRS{name}=="*Gamepad*",              MODE="0664"
SUBSYSTEM=="input", KERNEL=="event[0-9]*", \
    ATTRS{name}=="*GAMEPAD*",              MODE="0664"

# ── Xbox 360 무선 수신기 (VID:045e PID:0719) ────────────────────
SUBSYSTEM=="usb", ATTRS{idVendor}=="045e", ATTRS{idProduct}=="0719", \
    MODE="0664"

# ── PS2 USB 어댑터 (VID:0810 PID:0001) ──────────────────────────
SUBSYSTEM=="usb", ATTRS{idVendor}=="0810", ATTRS{idProduct}=="0001", \
    MODE="0664"

# ── 8BitDo 수신기 (VID:2dc8) ─────────────────────────────────────
SUBSYSTEM=="usb", ATTRS{idVendor}=="2dc8", MODE="0664"

# ── DS4 (VID:054c) ──────────────────────────────────────────────
SUBSYSTEM=="usb", ATTRS{idVendor}=="054c", MODE="0664"

# ── Bluetooth HID 입력 장치 ─────────────────────────────────────
SUBSYSTEM=="input", KERNEL=="event[0-9]*", \
    SUBSYSTEMS=="bluetooth",               MODE="0664"
