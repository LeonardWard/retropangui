#!/bin/sh
TAG="S99emulationstation"

case "$1" in
    start)
        logger -t "${TAG}" "Starting EmulationStation"
        # /dev/dri/card0 준비 대기 (최대 15초, S60display 이미 포그라운드 완료 후이므로 보통 즉시)
        i=0
        while [ $i -lt 30 ]; do
            [ -c /dev/dri/card0 ] && break
            sleep 0.5
            i=$((i + 1))
        done
        nohup sh -c '
            . /etc/retropangui.env
            export SDL_JOYSTICK_HIDAPI MESA_LOADER_DRIVER_OVERRIDE RETROPANGUI_SHARE LIBRETRO_CORES_PATH
            export HOME=/root
            # shutdown 신호 시 루프 종료 — stop 섹션이 SIGTERM을 보내면 클린 exit
            trap "exit 0" TERM INT
            while true; do
                # locale.conf는 루프 안에서 매번 다시 읽음 — ES 재시작만으로 언어 변경이 반영되게 함
                # (루프 밖에서 한 번만 읽으면 언어 변경 시 전체 재부팅이 있어야만 적용되는 문제 있었음)
                . /etc/locale.conf
                export LANG LC_ALL="$LANG"
                rm -f /tmp/es-restart /tmp/es-shutdown /tmp/es-sysrestart /tmp/es-kodi
                # HDMI 연결 대기 (최대 60초) — 뽑혀있으면 PHY/DRM 초기화가 실패함
                i=0
                while [ "$(cat /sys/devices/virtual/amhdmitx/amhdmitx0/hpd_state 2>/dev/null)" != "1" ] && [ $i -lt 60 ]; do
                    sleep 1; i=$((i+1))
                done
                # 2026-07-12: PHY 재활성화 로직 제거 - HDMI 재연결 시 PHY 복구는
                # udev 기반 /usr/sbin/hdmi-hotplug가 전담(중복 제거). 부팅/재시작
                # 경로에서는 아래 odroid-drm-fbset의 모드 설정이 출력 활성화를 겸함.
                killall odroid-drm-fbset 2>/dev/null || true
                # 2026-07-07: "preferred"는 모니터가 EDID로 자기 신고하는 1순위
                # 모드를 그대로 믿고 거는 방식인데, 실기기에서 이 모드가
                # 1920x1080p120hz로 잡히는 경우가 있고 일부 모니터/TV가 이
                # 120Hz를 제대로 못 받아서 스플래시 이후 화면이 완전히 안
                # 나오는 문제가 있었음(HDMI 재연결해야 복구됨) - 그래서
                # 새로고침율은 hdmi-set-resolution.py가 55~61Hz 범위 밖이면
                # 무조건 폴백하도록 안전장치를 둠(2026-07-11).
                # 주의: 이 블록은 바깥 sh -c '...'가 홑따옴표로 감싸고 있으므로
                # 여기 안에서는 절대 홑따옴표를 쓰지 말 것(중첩되면 스크립트가
                # 깨짐 - 실기기에서 실제로 겪은 문제, S60display도 동일 주의).
                HDMI_MODE="$(python3 /usr/share/retropangui/hdmi-set-resolution.py 2>>/var/log/hdmi-resolution.log)"
                [ -z "${HDMI_MODE}" ] && HDMI_MODE="1080p60hz"
                # 폴백 3단: 지정 모드 → 1080p → 720p(사실상 모든 HDMI 기기가
                # 받는 기본 CEA 모드). 모니터 교체 직후엔 화면이 안 보여서
                # 사람이 개입할 수 없으므로 어떤 모니터든 반드시 화면이
                # 나오는 데까지 자동으로 내려가야 함(2026-07-13 사용자 지적).
                FBSET_OUT="$(odroid-drm-fbset -outputmode "${HDMI_MODE}" || odroid-drm-fbset -outputmode 1080p60hz || odroid-drm-fbset -outputmode 720p60hz)"
                echo "${FBSET_OUT}"
                # 스플래시 비디오 재생 — ALSA softvol "Master" 컨트롤 초기화 목적
                # mpv가 오디오 디바이스를 열면 softvol 컨트롤이 등록되어 ES VolumeControl이 정상 작동함
                #
                # 2026-07-13: --drm-mode 명시 필수. mpv의 기본값이 preferred인데,
                # 모니터 교체 후 이전 모니터용 커스텀 모드가 preferred 플래그를
                # 쥐고 있으면 mpv가 그 죽은 모드로 바꿔버려서 위에서 적용한
                # 해상도가 무효화되고 "신호 없음"까지 감(실기기 실측 - 스플래시
                # 도중 disp_mode가 2560x1600으로 뒤집히는 걸 초 단위 추적으로
                # 확인). 방금 fbset이 성공한 모드(WxH@R)를 그대로 고정한다.
                MPV_MODE="$(echo "${FBSET_OUT}" | grep -oE "[0-9]+x[0-9]+@[0-9]+" | tail -1)"
                SPLASH="/usr/share/retropangui/splash/splash.mp4"
                if [ -f "${SPLASH}" ]; then
                    mpv --vo=drm --drm-device=/dev/dri/card0 \
                        ${MPV_MODE:+--drm-mode=${MPV_MODE}} \
                        --ao=alsa --audio-device=alsa/default \
                        "${SPLASH}" 2>/dev/null || true
                fi
                # 이전 RA가 kill되면 VT1 키보드가 K_MEDIUMRAW에 묶여 linuxraw 재초기화 실패
                # 매 ES 실행 전 K_XLATE(ASCII)로 리셋해서 linuxraw가 깨끗하게 초기화되도록 함
                kbd_mode -a 2>/dev/null || true
                # 2026-07-06: kbd 패키지(setfont 확보 목적) 추가 후 /usr/bin/openvt가
                # busybox 내장 openvt(-f가 항상 켜진 것처럼 동작, 검사 자체가 없음)를
                # 밀어내고 진짜 openvt(kbd 패키지, util-linux류)로 교체돼서 VT1이 이미
                # foreground 콘솔이면(특히 부팅 직후) "vt 1 is in use" 에러로 즉시
                # 실패 → ES가 아예 안 뜨고 스플래시만 무한 반복하는 회귀 발생(실기기
                # 확인). -f로 강제해서 기존 busybox 동작과 동일하게 복원.
                openvt -f -c 1 -s -w -- sh -c "
                    emulationstation --no-splash --no-exit --debug >> /var/log/es-launcher.log 2>&1 &
                    echo \$! > /tmp/es.pid
                    wait \$!
                    rm -f /tmp/es.pid
                "
                if [ -f /tmp/es-sysrestart ]; then
                    umount /retropangui/share 2>/dev/null || sync
                    reboot
                fi
                if [ -f /tmp/es-shutdown ]; then
                    umount /retropangui/share 2>/dev/null || sync
                    # S905X5M BL31이 PSCI SYSTEM_OFF 미구현 — poweroff는 do_aml_poweroff()
                    # 실패 후 커널 패닉→재부팅으로 이어진다.
                    # halt -f는 machine_halt()→while(1) 루프로 패닉 없이 정상 정지.
                    # 워치독 정지 필수 — 멈춘 후 타임아웃 재부팅 방지.
                    printf 'V' > /dev/watchdog0 2>/dev/null || true
                    halt -f
                fi
                if [ -f /tmp/es-kodi ]; then
                    rm -f /tmp/es-kodi
                    if command -v kodi >/dev/null 2>&1; then
                        killall odroid-drm-fbset 2>/dev/null; sleep 1
                        odroid-drm-fbset -outputmode preferred
                        # Kodi GBM이 dummy_l 등 무효 DRM 모드를 선택하는 버그 우회:
                        # odroid-drm-fbset preferred 결과로 guisettings.xml 해상도를 미리 고정.
                        KODI_GUI=/root/.kodi/userdata/guisettings.xml
                        if [ -f "$KODI_GUI" ]; then
                            PREF_MODE=$(odroid-drm-fbset -outputmode preferred 2>&1 | grep -oE "[0-9]+x[0-9]+" | head -1)
                            KW=$(echo "$PREF_MODE" | cut -dx -f1)
                            KH=$(echo "$PREF_MODE" | cut -dx -f2)
                            KHZ=$(odroid-drm-fbset -outputmode preferred 2>&1 | grep -oE "@[0-9]+" | tr -d '@' | head -1)
                            [ -z "$KW" ] && KW=1920
                            [ -z "$KH" ] && KH=1080
                            [ -z "$KHZ" ] && KHZ=60
                            KSCREENMODE="${KW}:${KH}:${KHZ}.00"
                            sed -i \
                                -e "s|<setting id=\"window.width\"[^>]*>[^<]*</setting>|<setting id=\"window.width\" default=\"true\">${KW}</setting>|" \
                                -e "s|<setting id=\"window.height\"[^>]*>[^<]*</setting>|<setting id=\"window.height\" default=\"true\">${KH}</setting>|" \
                                -e "s|<setting id=\"videoscreen.screenmode\"[^>]*>[^<]*</setting>|<setting id=\"videoscreen.screenmode\">${KSCREENMODE}</setting>|" \
                                "$KODI_GUI"
                        fi
                        env -u SDL_VIDEODRIVER -u MESA_LOADER_DRIVER_OVERRIDE \
                            LD_PRELOAD=/usr/lib64/libEGL.so.1 \
                            kodi --standalone >> /var/log/kodi.log 2>&1 || true
                        odroid-drm-fbset -outputmode preferred
                    fi
                    continue
                fi
                # ES가 종료되면 항상 재시작 (HDMI 재연결, 크래시 등 모든 경우 포함)
                sleep 2
            done
        ' > /var/log/es-launcher.log 2>&1 &
        echo $! > /var/run/es-launcher.pid
        ;;
    stop)
        # launcher 루프(nohup sh) 종료 — SIGTERM으로 trap 실행 후 clean exit
        if [ -f /var/run/es-launcher.pid ]; then
            kill "$(cat /var/run/es-launcher.pid)" 2>/dev/null || true
            rm -f /var/run/es-launcher.pid
        fi
        killall emulationstation 2>/dev/null || true
        killall openvt 2>/dev/null || true
        # VT 키보드를 ASCII 모드로 복원 — DRM 상태 클린업
        kbd_mode -a 2>/dev/null || true
        # ES PID 기반 종료 대기 — umount 성공을 위해 ES가 파일 핸들을 닫을 때까지 대기
        i=0
        while [ $i -lt 15 ]; do
            [ ! -f /tmp/es.pid ] && break
            kill -0 "$(cat /tmp/es.pid 2>/dev/null)" 2>/dev/null || break
            sleep 1; i=$((i+1))
        done
        sleep 1
        umount /retropangui/share 2>/dev/null || sync
        ;;
    restart|reload)
        "$0" stop
        sleep 1
        "$0" start
        ;;
    *)
        echo "Usage: $0 {start|stop|restart}"
        exit 1
        ;;
esac

exit 0
