#!/bin/sh
# S65rpui-bt - 블루투스 관리 데몬
#
# S61share 이후 실행 — /var/lib/bluetooth를 share 파티션으로 영속화하려면
# share가 먼저 마운트되어 있어야 한다. USB BT 동글 핫플러그 감지 및
# ES와의 IPC 담당. /etc/retropangui.env를 먼저 소스해서 RETROPANGUI_SHARE를
# 데몬에 전달한다 (S64rpui-wifi와 동일 규칙).
#
# /tmp/retropangui-bt-status.json 을 유지한다. CLI(rpui-bt 명령)는
# bluetoothctl을 직접 호출하므로 데몬과 별도 IPC 파일이 필요 없다.

TAG="S65rpui-bt"
DAEMON="/usr/bin/rpui-bt"
PIDFILE="/run/rpui-bt.pid"

case "$1" in
    start)
        [ -x "${DAEMON}" ] || { logger -t "${TAG}" "rpui-bt 없음, 건너뜀"; exit 0; }
        logger -t "${TAG}" "시작"
        . /etc/retropangui.env 2>/dev/null
        export RETROPANGUI_SHARE
        start-stop-daemon --start --quiet --background \
            --make-pidfile --pidfile "${PIDFILE}" \
            --exec "${DAEMON}" -- 2>&1 | logger -t "${TAG}"
        ;;
    stop)
        logger -t "${TAG}" "종료"
        start-stop-daemon --stop --quiet --pidfile "${PIDFILE}" --signal TERM
        rm -f "${PIDFILE}"
        ;;
    restart|reload)
        "$0" stop
        sleep 1
        "$0" start
        ;;
    *)
        echo "Usage: $0 {start|stop|restart}"
        exit 1
        ;;
esac

exit 0
