#!/bin/sh
TAG="S58gamepad"
PIDFILE=/var/run/gamepad-daemon.pid
DAEMON=gamepad-daemon

case "$1" in
    start)
        logger -t "${TAG}" "Starting gamepad daemon"
        SDL_JOYSTICK_HIDAPI=0 $DAEMON > /dev/null 2>&1 &
        echo $! > "$PIDFILE"
        i=0
        while [ $i -lt 20 ]; do
            grep -q "RetroPangUI P1" /proc/bus/input/devices && break
            sleep 0.5; i=$((i + 1))
        done
        if grep -q "RetroPangUI P1" /proc/bus/input/devices; then
            modprobe xpad 2>/dev/null || true
            logger -t "${TAG}" "xpad loaded after vdev creation"
        else
            logger -t "${TAG}" "WARNING: vdev not ready, loading xpad anyway"
            modprobe xpad 2>/dev/null || true
        fi
        ;;
    stop)
        logger -t "${TAG}" "Stopping gamepad daemon"
        [ -f "$PIDFILE" ] && kill "$(cat "$PIDFILE")" 2>/dev/null
        rm -f "$PIDFILE"
        ;;
    restart|reload) "$0" stop; "$0" start ;;
    *) echo "Usage: $0 {start|stop|restart}"; exit 1 ;;
esac
exit 0
