#!/bin/sh
# S60display - Initialize HDMI display via odroid-drm-fbset
# 포그라운드 실행 후 종료 (DRM master를 점유하지 않음)

case "$1" in
    start)
        echo "Starting display initialization..."
        # /dev/dri/card0 준비 대기 (최대 10초)
        i=0
        while [ $i -lt 20 ]; do
            [ -c /dev/dri/card0 ] && break
            sleep 0.5
            i=$((i + 1))
        done
        if [ ! -c /dev/dri/card0 ]; then
            echo "WARNING: /dev/dri/card0 not ready"
        fi
        if [ -x /usr/sbin/odroid-drm-fbset ]; then
            /usr/sbin/odroid-drm-fbset -outputmode 1920x1080p60hz 2>/dev/null || true
        else
            echo "odroid-drm-fbset not found"
        fi
        ;;
    stop)
        ;;
    restart|reload)
        "$0" stop
        "$0" start
        ;;
    *)
        echo "Usage: $0 {start|stop|restart}"
        exit 1
        ;;
esac

exit 0
