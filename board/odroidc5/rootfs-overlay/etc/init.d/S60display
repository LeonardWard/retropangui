#!/bin/sh
TAG="S60display"

case "$1" in
    start)
        i=0
        while [ $i -lt 20 ]; do
            [ -c /dev/dri/card0 ] && break
            sleep 0.5; i=$((i + 1))
        done
        [ ! -c /dev/dri/card0 ] && logger -t "${TAG}" "WARNING: /dev/dri/card0 not ready"
        if [ -x /usr/sbin/odroid-drm-fbset ]; then
            # 2026-07-21 재설계: S60display는 S61share(share 파티션 마운트,
            # retropangui.conf가 있는 곳)보다 먼저 실행되므로(S60 < S61),
            # 이 시점에 EDID 자동감지나 사용자 설정(system.hdmi_resolution)을
            # 읽으려 하는 건 원천적으로 신뢰할 수 없음(실기기에서 auto로
            # 잘못 폴백되는 걸로 확인 - 사용자 지적: "S60 마운트 전엔 720p
            # 강제, 마운트 후엔 retropangui.conf 값 적용이 자연스럽다").
            # 그래서 S60은 EDID/conf를 아예 건드리지 않고, /boot/config.ini
            # (initramfs 단계부터 이미 마운트돼 있어 안전) 의 displaymode
            # 값을 그대로 강제 적용하는 "안전한 임시 기본값" 역할만 한다.
            # 진짜 최종 해상도 결정은 S99emulationstation(공유 마운트 이후,
            # apply-resolution.sh를 매 회차 정상 호출)이 전담 - 상세:
            # todo-20260713-display-followups.html 2번 항목.
            BOOT_MODE="$(sed -nE 's/^displaymode="?([^"]*)"?/\1/p' /boot/config.ini 2>/dev/null | head -1)"
            [ -z "${BOOT_MODE}" ] && BOOT_MODE="1080p60hz"
            /usr/sbin/odroid-drm-fbset -outputmode "${BOOT_MODE}" 2>/dev/null \
                || /usr/sbin/odroid-drm-fbset -outputmode 1080p60hz 2>/dev/null || true
            # 2026-07-11: HDMI Content-Type을 "game"으로 신고 - 이 값을
            # 지원하는(EDID CNC3 비트) TV/모니터에서 자동으로 저지연
            # 게임모드가 켜짐. 미지원 기기에서는 커널이 조용히 무시함
            # (hdmitx_sysfs_common.c의 prxcap->cnc3 체크) - 안전하게 항상 시도.
            echo game > /sys/class/amhdmitx/amhdmitx0/contenttype_mode 2>/dev/null || true
            logger -t "${TAG}" "Display initialized (boot default: ${BOOT_MODE})"
        else
            logger -t "${TAG}" "odroid-drm-fbset not found"
        fi
        ;;
    stop) ;;
    restart|reload) "$0" stop; "$0" start ;;
    *) echo "Usage: $0 {start|stop|restart}"; exit 1 ;;
esac
