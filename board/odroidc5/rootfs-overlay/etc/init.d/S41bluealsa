#!/bin/sh
# S41bluealsa - 블루투스 오디오(A2DP) ALSA 브릿지 데몬
#
# S40bluetoothd 다음 실행 - bluetoothd의 D-Bus 서비스가 먼저 떠 있어야 함.
# a2dp-sink 프로파일만 사용(이 기기가 스피커로 소리를 "보내는" 쪽이라
# source/hfp는 불필요). asound.conf의 "type bluealsa" pcm이 이 데몬을
# 통해 실제 블루투스 오디오 장치와 통신한다.
# 2026-07-11: bt-audio-autoswitch.py(S66btaudio)와 세트로 도입.

DAEMON="bluealsa"
PIDFILE="/var/run/${DAEMON}.pid"

case "$1" in
    start)
        printf 'Starting %s: ' "${DAEMON}"
        start-stop-daemon -S -q -m -b -p "${PIDFILE}" -x "/usr/bin/${DAEMON}" \
            -- -p a2dp-sink
        [ $? -eq 0 ] && echo "OK" || echo "FAIL"
        ;;
    stop)
        printf 'Stopping %s: ' "${DAEMON}"
        start-stop-daemon -K -q -p "${PIDFILE}"
        [ $? -eq 0 ] && echo "OK" || echo "FAIL"
        ;;
    restart|reload)
        "$0" stop
        sleep 1
        "$0" start
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|reload}"
        exit 1
        ;;
esac
