#!/bin/sh
# S99sunshine - Sunshine(Moonlight 호환 원격 스트리밍 서버) 데몬
#
# 다른 기기에서 이 화면을 보고 조작하기 위한 원격 디버깅/확인용 도구 -
# 기본적으로 꺼져 있음(retropangui.conf의 system.remote_streaming=true일
# 때만 기동, 2026-07-16). S99emulationstation 다음 실행(알파벳순
# S99emulationstation < S99sunshine) - KMS 캡처가 잡을 화면 내용(ES)이
# 이미 떠 있는 상태에서 인코더 검증이 이뤄지게 하기 위함
# (todo-20260709-remote-streaming.html 참고 - ES 등 DRM 클라이언트가
# 없으면 캡처할 plane 자체가 없어 인코더 검증이 실패함).

TAG="S99sunshine"
DAEMON="/usr/bin/sunshine"
PIDFILE="/run/sunshine.pid"
RP_CONF="/retropangui/share/system/retropangui.conf"
SUNSHINE_CONF_DIR="/root/.config/sunshine"
SUNSHINE_CONF="${SUNSHINE_CONF_DIR}/sunshine.conf"

is_enabled() {
    [ -f "${RP_CONF}" ] || return 1
    val=$(grep -E "^system\.remote_streaming[[:space:]]*=" "${RP_CONF}" | tail -1 | sed 's/^[^=]*=//' | tr -d ' \r')
    [ "${val}" = "true" ]
}

# 현재 이 기기의 IPv4 주소들을 CSRF 허용 origin으로 등록 - DHCP로 IP가
# 바뀌어도 매 부팅 시 다시 계산되므로 재발 안 함(2026-07-16 이전엔 라이브로
# 한 IP만 수동 등록했다가 IP가 바뀌자 막혔던 문제 있었음).
build_csrf_origins() {
    ips=$(ip -4 addr show scope global 2>/dev/null | awk '/inet /{print $2}' | cut -d/ -f1)
    origins=""
    for ip in ${ips}; do
        [ -n "${origins}" ] && origins="${origins},"
        origins="${origins}https://${ip}"
    done
    echo "${origins}"
}

write_sunshine_conf() {
    mkdir -p "${SUNSHINE_CONF_DIR}"
    origins=$(build_csrf_origins)
    cat > "${SUNSHINE_CONF}" <<EOF
capture = kms
encoder = software
csrf_allowed_origins = ${origins}
EOF
}

case "$1" in
    start)
        if ! is_enabled; then
            logger -t "${TAG}" "비활성화됨(system.remote_streaming=false) - 건너뜀"
            exit 0
        fi
        [ -x "${DAEMON}" ] || { logger -t "${TAG}" "sunshine 바이너리 없음, 건너뜀"; exit 0; }
        write_sunshine_conf
        logger -t "${TAG}" "시작"
        start-stop-daemon --start --quiet --background \
            --make-pidfile --pidfile "${PIDFILE}" \
            --exec "${DAEMON}" -- "${SUNSHINE_CONF}" 2>&1 | logger -t "${TAG}"
        ;;
    stop)
        logger -t "${TAG}" "종료"
        start-stop-daemon --stop --quiet --pidfile "${PIDFILE}" --signal TERM
        rm -f "${PIDFILE}"
        ;;
    restart|reload)
        "$0" stop
        sleep 1
        "$0" start
        ;;
    *)
        echo "Usage: $0 {start|stop|restart}"
        exit 1
        ;;
esac

exit 0
