#!/bin/sh
# S63ntp - 시각 초기화 및 NTP 동기화
# S61share(마운트) 이후 실행 → fake-hwclock을 share 파티션에 영구 보존 가능
# fake-hwclock: RTC 없는 시스템에서 에폭(1970) 기동 방지
DAEMON=/usr/sbin/ntpd
PIDFILE=/run/ntpd.pid
FAKEHWCLOCK=/retropangui/share/system/fake-hwclock

[ -x "${DAEMON}" ] || exit 0

case "$1" in
    start)
        # 1. fake-hwclock 복원 (UTC)
        if [ -f "${FAKEHWCLOCK}" ]; then
            date -u -s "$(cat ${FAKEHWCLOCK})" 2>/dev/null
        else
            date -u -s "2026-06-17 00:00:00" 2>/dev/null
        fi

        # 2. 네트워크(기본 라우트) 대기 — 최대 10초, 포그라운드
        i=0
        while [ $i -lt 10 ]; do
            route -n 2>/dev/null | grep -q "^0\.0\.0\.0" && break
            sleep 1
            i=$((i + 1))
        done

        # 3. Google HTTPS Date 헤더로 즉시 시각 보정 — ntpd 시작 전 포그라운드 실행
        # openntpd는 오프셋이 수십 일 이상이면 step을 거부하므로
        # ntpd 시작 전에 반드시 현재 시각에 가깝게 맞춰야 한다.
        HTTPDATE=$(wget --no-check-certificate --timeout=10 --server-response \
            -O /dev/null https://www.google.com 2>&1 \
            | grep -i "Date:" | head -1 | sed "s/.*Date: //")
        if [ -n "$HTTPDATE" ]; then
            SETDATE=$(echo "$HTTPDATE" | awk '{
                split("Jan Feb Mar Apr May Jun Jul Aug Sep Oct Nov Dec", m, " ")
                for(i=1;i<=12;i++) if(m[i]==$3) mon=sprintf("%02d",i)
                printf "%s-%s-%s %s\n", $4, mon, $2, $5
            }')
            if [ -n "$SETDATE" ]; then
                date -u -s "$SETDATE" 2>/dev/null
                echo "NTP: Google Date 시각 설정: $SETDATE UTC"
            fi
        fi

        # 4. ntpd 시작 — 이미 시각이 맞으므로 소폭 오프셋만 slew/step 처리
        echo "Starting NTP..."
        kill $(cat "${PIDFILE}" 2>/dev/null) 2>/dev/null || true
        rm -f "${PIDFILE}"
        "${DAEMON}" -s -p "${PIDFILE}"
        ;;
    stop)
        echo "Stopping NTP..."
        # 종료 전 현재 시각 저장 (다음 부팅을 위한 fake-hwclock)
        mkdir -p "$(dirname ${FAKEHWCLOCK})"
        date -u +"%Y-%m-%d %H:%M:%S" > "${FAKEHWCLOCK}" 2>/dev/null
        kill $(cat "${PIDFILE}" 2>/dev/null) 2>/dev/null || true
        rm -f "${PIDFILE}"
        ;;
    restart|reload)
        "$0" stop; sleep 1; "$0" start
        ;;
    *)
        echo "Usage: $0 {start|stop|restart}"; exit 1
        ;;
esac
exit 0
