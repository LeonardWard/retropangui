#!/bin/sh
TAG="S62audio"

start() {
    modprobe amlogic-snd-codec-dummy 2>/dev/null || true
    modprobe amlogic-snd-codec-t9015 2>/dev/null || true
    # 2026-07-13: USB MIDI(외장 MT-32 에뮬 기기 등)를 ALSA 시퀀서 포트로
    # 노출하는 다리 모듈 - 이게 없으면 rawmidi(/dev/snd/midiC*)까지는
    # 잡혀도 aplaymidi/RetroArch(alsa 시퀀서 기반)가 장치를 전혀 못 봐서
    # dosbox-pure가 "frontend MIDI output is not set up correctly"를 냄
    # (실기기 규명). 커널이 rawmidi 등록 시 자동 로드해주지 않는 고전적
    # 케이스라 명시 로드 필요.
    modprobe snd_seq_midi 2>/dev/null || true
    # 2026-07-11: CARD=0 하드코딩 버그 - USB 오디오 장치(예: 컨트롤러에
    # 내장된 오디오 인터페이스)가 온보드 HDMI 오디오(AML-AUGESOUND)보다
    # 먼저 등록되면 카드 번호가 밀려서(0이 USB, 1이 온보드) 이 스크립트가
    # 엉뚱한 카드를 건드리고 실제 HDMI 오디오 라우팅이 안 되는 문제가
    # 있었음(실기기에서 소리가 완전히 안 나오는 증상으로 확인). 이름으로
    # 찾도록 수정.
    CARD=""
    i=0
    while [ $i -lt 10 ]; do
        CARD=$(awk -F'[][]' '/\[AMLAUGESOUND/{print $1; exit}' /proc/asound/cards 2>/dev/null | tr -d ' ')
        [ -n "${CARD}" ] && break
        sleep 0.5; i=$((i+1))
    done
    if [ -z "${CARD}" ]; then
        logger -t "${TAG}" "WARNING: AML-AUGESOUND card not found"
        return 1
    fi
    amixer -c ${CARD} sset "HDMITX Audio Source Select" "Tdm_B" 2>/dev/null || true
    amixer -c ${CARD} sset "Audio I2S to HDMITX Mask"  1       2>/dev/null || true
    amixer -c ${CARD} sset "Audio hdmi-out mute"        0       2>/dev/null || true
    amixer -c ${CARD} sset "TDMOUT_B Mute"              0       2>/dev/null || true
    amixer -c ${CARD} sset "TDMOUT_B Lane0 Mute"        0       2>/dev/null || true
    amixer -c ${CARD} sset "TDMOUT_B Lane1 Mute"        0       2>/dev/null || true
    amixer -c ${CARD} sset "TDMOUT_B GAIN"              255     2>/dev/null || true
    amixer -c ${CARD} sset "TDMOUT_B Software Gain"     100     2>/dev/null || true
    # 2026-07-18: PA(S50)가 이 스크립트보다 먼저 떠서 TDM PCM을 여는 순서라,
    # hdmitx가 위 라우팅 설정 "이전" 상태(aud_src_if=0, SPDIF)로 래치된 채
    # 굳는 무음이 실기기에서 규명됨 - 컨트롤은 나중에 바꿔도 PCM re-prepare가
    # 없으면 hdmitx에 반영되지 않는다(suspend/resume 재래치로 소리 복귀 실증,
    # todo-20260716-pulseaudio-migration.html). 라우팅 확정 직후 sink를 한 번
    # suspend→resume해서 올바른 컨트롤 상태로 강제 재프리페어한다.
    if command -v pactl >/dev/null 2>&1; then
        SINK=$(pactl list sinks short 2>/dev/null | awk 'NR==1{print $2}')
        if [ -n "${SINK}" ]; then
            pactl suspend-sink "${SINK}" 1 2>/dev/null || true
            sleep 0.3
            pactl suspend-sink "${SINK}" 0 2>/dev/null || true
            logger -t "${TAG}" "PA sink 재래치 완료 (${SINK})"
        fi
    fi

    logger -t "${TAG}" "Audio ready (HDMI)"
}

case "$1" in
    start) start ;;
    stop) : ;;
    restart) start ;;
    *) echo "Usage: $0 {start|stop|restart}"; exit 1 ;;
esac
