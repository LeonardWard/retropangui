#!/bin/sh
TAG="S98ntp"
DAEMON=/usr/sbin/ntpd
PIDFILE=/run/ntpd.pid
FAKEHWCLOCK=/retropangui/share/system/fake-hwclock

[ -x "${DAEMON}" ] || exit 0

case "$1" in
    start)
        if [ -f "${FAKEHWCLOCK}" ]; then
            date -u -s "$(cat ${FAKEHWCLOCK})" 2>/dev/null
        else
            date -u -s "2026-06-18 00:00:00" 2>/dev/null
        fi
        kill $(cat "${PIDFILE}" 2>/dev/null) 2>/dev/null || true
        rm -f "${PIDFILE}"
        {
            i=0
            while [ $i -lt 30 ]; do
                route -n 2>/dev/null | grep -q "^0\.0\.0\.0" && break
                sleep 1; i=$((i + 1))
            done
            HTTPDATE=$(wget --no-check-certificate --server-response \
                -O /dev/null https://www.google.com 2>&1 \
                | grep -i "Date:" | head -1 | sed "s/.*Date: //")
            if [ -n "$HTTPDATE" ]; then
                SETDATE=$(echo "$HTTPDATE" | awk '{
                    split("Jan Feb Mar Apr May Jun Jul Aug Sep Oct Nov Dec", m, " ")
                    for(i=1;i<=12;i++) if(m[i]==$3) mon=sprintf("%02d",i)
                    printf "%s-%s-%s %s\n", $4, mon, $2, $5
                }')
                [ -n "$SETDATE" ] && date -u -s "$SETDATE" 2>/dev/null && \
                    logger -t "${TAG}" "Google Date: $SETDATE UTC"
            fi
            "${DAEMON}" -p "${PIDFILE}"
        } &
        ;;
    stop)
        mkdir -p "$(dirname ${FAKEHWCLOCK})"
        date -u +"%Y-%m-%d %H:%M:%S" > "${FAKEHWCLOCK}" 2>/dev/null
        kill $(cat "${PIDFILE}" 2>/dev/null) 2>/dev/null || true
        rm -f "${PIDFILE}"
        ;;
    restart|reload) "$0" stop; sleep 1; "$0" start ;;
    *) echo "Usage: $0 {start|stop|restart}"; exit 1 ;;
esac
exit 0
