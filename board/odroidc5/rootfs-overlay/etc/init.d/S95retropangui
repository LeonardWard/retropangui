#!/bin/sh
# S95retropangui - RetroPangui 설정 초기화 및 적용
# S61share(마운트) 이후, S99emulationstation(ES 실행) 이전에 실행

CONF_DEFAULT="/opt/retropangui/share/retropangui.conf.default"
CONF_USER="/retropangui/share/system/retropangui.conf"
RA_CFG_DEFAULT="/opt/retropangui/retroarch.cfg"
RA_CFG_USER="/retropangui/share/system/retroarch/retroarch.cfg"
ES_CFG_USER="/retropangui/share/system/emulationstation/es_settings.cfg"
APPLY_SCRIPT="/opt/retropangui/share/apply_retropangui_conf.sh"

case "$1" in
    start)
        # /retropangui/share 파티션이 마운트될 때까지 대기 (최대 10초)
        i=0
        while [ $i -lt 10 ]; do
            grep -q " /retropangui/share " /proc/mounts && break
            sleep 1
            i=$((i + 1))
        done

        if ! grep -q " /retropangui/share " /proc/mounts; then
            echo "[retropangui] /retropangui/share 파티션이 마운트되지 않았습니다. 설정 적용 건너뜀."
            exit 0
        fi

        # CPU/GPU: schedutil/ondemand는 게임 중 최저 주파수에 머물 수 있어 performance로 고정
        for gov in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do
            echo performance > "$gov" 2>/dev/null || true
        done
        MALI_DEVFREQ=$(ls /sys/class/misc/mali0/device/devfreq/ 2>/dev/null | head -1)
        if [ -n "$MALI_DEVFREQ" ]; then
            echo performance > /sys/class/misc/mali0/device/devfreq/${MALI_DEVFREQ}/governor 2>/dev/null || true
        fi

        # 디렉토리 생성
        mkdir -p /retropangui/share/system/retroarch
        mkdir -p /retropangui/share/system/emulationstation

        # /root/.emulationstation → /retropangui/share/system/emulationstation 심볼릭 링크
        if [ ! -L /root/.emulationstation ]; then
            rm -rf /root/.emulationstation
            ln -sfn /retropangui/share/system/emulationstation /root/.emulationstation
        fi

        # 첫 부팅: retropangui.conf 없으면 기본값에서 복사
        if [ ! -f "${CONF_USER}" ]; then
            if [ -f "${CONF_DEFAULT}" ]; then
                echo "[retropangui] 첫 부팅: 기본 설정 파일 복사 중..."
                cp "${CONF_DEFAULT}" "${CONF_USER}"
                echo "[retropangui] ${CONF_USER} 생성 완료"
            else
                echo "[retropangui] 기본 설정 파일 없음: ${CONF_DEFAULT}"
                exit 0
            fi
        fi

        # 첫 부팅: retroarch.cfg 없으면 기본값에서 복사
        if [ ! -f "${RA_CFG_USER}" ]; then
            echo "[retropangui] 첫 부팅: retroarch.cfg 복사 중..."
            cp "${RA_CFG_DEFAULT}" "${RA_CFG_USER}"
        fi

        # 첫 부팅: es_settings.cfg 없으면 최소 XML 골격 생성
        # (빈 파일이면 EmulationStation이 "No document element found" 에러 발생)
        if [ ! -f "${ES_CFG_USER}" ] || ! grep -q "<config" "${ES_CFG_USER}" 2>/dev/null; then
            echo "[retropangui] es_settings.cfg XML 골격 생성 중..."
            printf '<?xml version="1.0"?>\n<config>\n</config>\n' > "${ES_CFG_USER}"
        fi

        # 첫 부팅: retroarch-core-options.cfg 없으면 기본값에서 복사
        RA_CORE_OPTS_SRC="/opt/retropangui/retroarch-core-options.cfg"
        RA_CORE_OPTS_DST="/retropangui/share/system/retroarch/retroarch-core-options.cfg"
        if [ ! -f "${RA_CORE_OPTS_DST}" ] && [ -f "${RA_CORE_OPTS_SRC}" ]; then
            echo "[retropangui] 첫 부팅: retroarch-core-options.cfg 복사 중..."
            cp "${RA_CORE_OPTS_SRC}" "${RA_CORE_OPTS_DST}"
        fi

        # 첫 부팅: es_input.cfg 없으면 기본값에서 복사
        ES_INPUT_SRC="/opt/retropangui/share/es_input.cfg"
        ES_INPUT_DST="/retropangui/share/system/emulationstation/es_input.cfg"
        if [ ! -f "${ES_INPUT_DST}" ] && [ -f "${ES_INPUT_SRC}" ]; then
            echo "[retropangui] 첫 부팅: es_input.cfg 복사 중..."
            cp "${ES_INPUT_SRC}" "${ES_INPUT_DST}"
        fi

        # 첫 부팅: 테마 없으면 기본값에서 복사
        THEMES_SRC="/opt/retropangui/themes"
        THEMES_DST="/retropangui/share/system/emulationstation/themes"
        if [ ! -d "${THEMES_DST}" ] && [ -d "${THEMES_SRC}" ]; then
            echo "[retropangui] 첫 부팅: 테마 복사 중..."
            mkdir -p "${THEMES_DST}"
            cp -r "${THEMES_SRC}/." "${THEMES_DST}/"
        fi

        # 설정 적용 (retropangui.conf → retroarch.cfg, es_settings.cfg)
        if [ -x "${APPLY_SCRIPT}" ]; then
            "${APPLY_SCRIPT}" "${CONF_USER}"
        else
            echo "[retropangui] apply 스크립트 없음: ${APPLY_SCRIPT}"
        fi

        # gamepad-daemon이 vdev를 생성할 때까지 대기 (최대 10초)
        i=0
        while [ $i -lt 20 ]; do
            grep -q "RetroPangUI P1" /proc/bus/input/devices && break
            sleep 0.5; i=$((i+1))
        done
        if ! grep -q "RetroPangUI P1" /proc/bus/input/devices; then
            echo "[retropangui] WARNING: RetroPangUI P1 not found in /proc/bus/input/devices (timeout)" | tee -a /var/log/retropangui.log
        fi

        # RA가 이전 세션에 저장한 joypad_index를 모두 제거하고 evdev 스캔으로 재계산한다.
        if [ -f "${RA_CFG_USER}" ]; then
            sed -i '/^input_player[0-9]*_joypad_index /d' "${RA_CFG_USER}"

            # /proc/bus/input/devices를 event 번호 오름차순으로 정렬해 RA의 열거 순서와 일치시킨다.
            gp_list=$(awk '
                function hextodec(hex,    i,c,d,v) {
                    v=0; for(i=1;i<=length(hex);i++) {
                        c=substr(hex,i,1)
                        if(c~/[0-9]/) d=c+0
                        else if(c~/[a-f]/) d=index("abcdef",c)+9
                        else if(c~/[A-F]/) d=index("ABCDEF",c)+9
                        else d=0
                        v=v*16+d
                    }
                    return v
                }
                function hexnibble(c) {
                    if(c~/[0-9]/) return c+0
                    if(c~/[a-f]/) return index("abcdef",c)+9
                    if(c~/[A-F]/) return index("ABCDEF",c)+9
                    return 0
                }
                function bit_in_hex(hexstr, bitpos,    ni,hlen,nv,i) {
                    ni=int(bitpos/4); hlen=length(hexstr)
                    if(ni>=hlen) return 0
                    nv=hexnibble(substr(hexstr,hlen-ni,1))
                    for(i=0;i<bitpos%4;i++) nv=int(nv/2)
                    return nv%2
                }
                /^N: Name=/ { name=substr($0,index($0,"=")+2); gsub(/"/,"",name) }
                /^H: Handlers=/ {
                    evnum=-1
                    for(j=1;j<=NF;j++) {
                        f=$j; sub(/.*=/, "", f)
                        if(f~/^event[0-9]/) evnum=substr(f,6)+0
                    }
                }
                /^B: EV=/ {
                    ev=hextodec(substr($0,index($0,"=")+1))
                    is_gp=(int(ev/2)%2 && int(ev/8)%2) ? 1 : 0
                }
                /^B: KEY=/ {
                    keyline=substr($0,index($0,"=")+1)
                    nk=split(keyline,kchunks," "); has_btn=0
                    if(nk>=5) {
                        c4=kchunks[nk-4]
                        if(bit_in_hex(c4,32) || bit_in_hex(c4,48)) has_btn=1
                    }
                }
                /^[[:space:]]*$/ {
                    if(is_gp && has_btn && evnum>=0) printf "%05d\t%s\n",evnum,name
                    name=""; evnum=-1; is_gp=0; has_btn=0
                }
            ' /proc/bus/input/devices | sort)

            # SDL이 첫 번째 가상 패드(가장 낮은 event#)를 열 때 RA가 해당 장치를
            # 목록 맨 뒤로 재배치한다. 이를 보정하기 위해 -1 rotation을 적용한다.
            num_phys=$(echo "$gp_list" | grep -v "RetroPangUI" | wc -l | tr -d ' ')
            num_virt=$(echo "$gp_list" | grep -c "RetroPangUI")
            virt_list=$(echo "$gp_list" | grep "RetroPangUI")

            for p in 1 2 3 4; do
                evdev_virt_rank=$(echo "$virt_list" | awk -v target="RetroPangUI P${p}" '
                    BEGIN { i=0 }
                    { if(index($0,target)) { print i; exit }; i++ }
                ')

                [ -z "$evdev_virt_rank" ] && {
                    echo "[retropangui] WARNING: RetroPangUI P${p} not found in gamepad list" | tee -a /var/log/retropangui.log
                    continue
                }

                ra_virt_rank=$(( (evdev_virt_rank - 1 + num_virt) % num_virt ))
                idx=$((num_phys + ra_virt_rank))

                if grep -q "^input_player${p}_joypad_index " "${RA_CFG_USER}"; then
                    sed -i "s|^input_player${p}_joypad_index = .*|input_player${p}_joypad_index = \"${idx}\"|" "${RA_CFG_USER}"
                else
                    echo "input_player${p}_joypad_index = \"${idx}\"" >> "${RA_CFG_USER}"
                fi
                echo "[retropangui] RetroPangUI P${p} → joypad index ${idx}" | tee -a /var/log/retropangui.log
            done
        fi
        ;;
    stop)
        ;;
    restart|reload)
        "$0" start
        ;;
    *)
        echo "Usage: $0 {start|stop|restart}"
        exit 1
        ;;
esac

exit 0
