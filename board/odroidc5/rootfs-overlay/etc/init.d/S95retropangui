#!/bin/sh
TAG="S95retropangui"
CONF_DEFAULT="/usr/share/retropangui/retropangui.conf.default"
CONF_USER="/retropangui/share/system/retropangui.conf"
RA_CFG_DEFAULT="/etc/retroarch.cfg"
RA_CFG_USER="/retropangui/share/system/retroarch/retroarch.cfg"
ES_CFG_USER="/retropangui/share/system/emulationstation/es_settings.cfg"
APPLY_SCRIPT="/usr/share/retropangui/apply_retropangui_conf.sh"
RA_LIBRETRO_DIR="/usr/lib/libretro"
RA_LIBRETRO_INFO="/usr/share/libretro/info"
RA_ASSETS_DIR="/usr/share/retroarch"
RA_BIOS_DIR="/retropangui/share/bios"

case "$1" in
    start)
        # /retropangui/share 파티션이 마운트될 때까지 대기 (최대 10초)
        i=0
        while [ $i -lt 10 ]; do
            grep -q " /retropangui/share " /proc/mounts && break
            sleep 1
            i=$((i + 1))
        done

        if ! grep -q " /retropangui/share " /proc/mounts; then
            logger -t "${TAG}" "/retropangui/share 마운트 안 됨 — 설정 적용 건너뜀"
            exit 0
        fi

        # CPU/GPU: schedutil/ondemand는 게임 중 최저 주파수에 머물 수 있어 performance로 고정
        for gov in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do
            echo performance > "$gov" 2>/dev/null || true
        done
        MALI_DEVFREQ=$(ls /sys/class/misc/mali0/device/devfreq/ 2>/dev/null | head -1)
        if [ -n "$MALI_DEVFREQ" ]; then
            echo performance > /sys/class/misc/mali0/device/devfreq/${MALI_DEVFREQ}/governor 2>/dev/null || true
        fi

        # 디렉토리 생성 (music 등 share 하위 폴더는 S61share가 마운트 시 생성)
        mkdir -p /retropangui/share/system/retroarch
        mkdir -p /retropangui/share/system/emulationstation

        # /root/.emulationstation → /retropangui/share/system/emulationstation 심볼릭 링크
        if [ ! -L /root/.emulationstation ]; then
            rm -rf /root/.emulationstation
            ln -sfn /retropangui/share/system/emulationstation /root/.emulationstation
        fi

        # (구) /root/share → /retropangui/share 심볼릭 링크는 제거됨.
        # ES가 RETROPANGUI_SHARE 환경 변수(S99에서 export)로 직접 경로를 찾으므로
        # $HOME/share 폴백 우회책이 더 이상 필요 없음. 잔존 링크는 정리.
        [ -L /root/share ] && rm -f /root/share

        # apply_retropangui_conf.sh 실행 여부: 최초 부팅(retropangui.conf 없음)에만 실행
        # conf.default 키 병합 시에는 실행하지 않는다 — apply는 초기 세팅 목적이므로 1회만
        APPLY_NEEDED=false

        # 첫 부팅: retropangui.conf 없으면 기본값에서 복사
        if [ ! -f "${CONF_USER}" ]; then
            if [ -f "${CONF_DEFAULT}" ]; then
                logger -t "${TAG}" "첫 부팅: 기본 설정 파일 복사 중..."
                cp "${CONF_DEFAULT}" "${CONF_USER}"
                logger -t "${TAG}" "${CONF_USER} 생성 완료"
                # es_settings.cfg가 이미 있으면 사용자가 이전에 설정한 값이므로 apply 건너뜀
                # (retropangui.conf만 없어진 경우 — apply하면 사용자 설정이 conf.default로 덮어씌워짐)
                if [ ! -f "${ES_CFG_USER}" ]; then
                    APPLY_NEEDED=true
                else
                    logger -t "${TAG}" "es_settings.cfg 존재 — apply 건너뜀 (사용자 설정 보존)"
                fi
            else
                logger -t "${TAG}" "기본 설정 파일 없음: ${CONF_DEFAULT}"
                exit 0
            fi
        elif [ -f "${CONF_DEFAULT}" ]; then
            # conf.default에 새로 추가된 키가 user conf에 없으면 병합
            # (펌웨어 업데이트로 새 키가 추가된 경우)
            while IFS='=' read -r def_key def_val || [ -n "${def_key}" ]; do
                case "${def_key}" in
                    '#'*|'') continue ;;
                esac
                def_key="$(echo "${def_key}" | sed 's/[[:space:]]*$//')"
                [ -z "${def_key}" ] && continue
                if ! grep -q "^${def_key}[[:space:]]*=" "${CONF_USER}" 2>/dev/null; then
                    echo "${def_key}=${def_val}" >> "${CONF_USER}"
                    logger -t "${TAG}" "conf 병합: ${def_key}"
                fi
            done < "${CONF_DEFAULT}"
        fi

        # 첫 부팅: retroarch.cfg 없으면 빈 파일 생성
        # 기본값은 appendconfig(/etc/retroarch.cfg)에서 제공. 사용자 변경분만 여기에 기록.
        if [ ! -f "${RA_CFG_USER}" ]; then
            logger -t "${TAG}" "첫 부팅: retroarch.cfg 빈 파일 생성"
            touch "${RA_CFG_USER}"
        fi

        # 첫 부팅: es_settings.cfg 없으면 최소 XML 골격 생성
        # (빈 파일이면 EmulationStation이 "No document element found" 에러 발생)
        # 주의: 파일이 이미 존재하면 덮어쓰지 않는다. ES가 saveFile()로 직접 관리한다.
        if [ ! -f "${ES_CFG_USER}" ]; then
            logger -t "${TAG}" "es_settings.cfg XML 골격 생성"
            printf '<?xml version="1.0"?>\n<config>\n</config>\n' > "${ES_CFG_USER}"
        fi

        # 첫 부팅: retroarch-core-options.cfg 없으면 기본값에서 복사
        RA_CORE_OPTS_SRC="/usr/share/retropangui/retroarch-core-options.cfg"
        RA_CORE_OPTS_DST="/retropangui/share/system/retroarch/retroarch-core-options.cfg"
        if [ ! -f "${RA_CORE_OPTS_DST}" ] && [ -f "${RA_CORE_OPTS_SRC}" ]; then
            logger -t "${TAG}" "첫 부팅: retroarch-core-options.cfg 복사"
            cp "${RA_CORE_OPTS_SRC}" "${RA_CORE_OPTS_DST}"
        fi

        # 첫 부팅: es_input.cfg 없으면 기본값에서 복사
        ES_INPUT_SRC="/usr/share/retropangui/es_input.cfg"
        ES_INPUT_DST="/retropangui/share/system/emulationstation/es_input.cfg"
        if [ ! -f "${ES_INPUT_DST}" ] && [ -f "${ES_INPUT_SRC}" ]; then
            logger -t "${TAG}" "첫 부팅: es_input.cfg 복사"
            cp "${ES_INPUT_SRC}" "${ES_INPUT_DST}"
        fi

        # 첫 부팅: 테마 없으면 기본값에서 복사
        THEMES_SRC="/usr/share/retropangui/themes"
        THEMES_DST="/retropangui/share/system/emulationstation/themes"
        if [ ! -d "${THEMES_DST}" ] && [ -d "${THEMES_SRC}" ]; then
            logger -t "${TAG}" "첫 부팅: 테마 복사"
            mkdir -p "${THEMES_DST}"
            cp -r "${THEMES_SRC}/." "${THEMES_DST}/"
        fi

        # 시스템별 스크린샷 디렉토리 및 .retroarch.cfg 초기화
        # es_systems.xml에서 시스템 이름 추출 → 없을 때만 생성 (사용자 커스텀 보존)
        SYSTEMS_XML="/etc/emulationstation/es_systems.xml"
        ROMS_ROOT="/retropangui/share/roms"
        SCREENSHOTS_ROOT="/retropangui/share/screenshots"
        if [ -f "${SYSTEMS_XML}" ]; then
            grep '<name>' "${SYSTEMS_XML}" | sed 's/.*<name>\(.*\)<\/name>.*/\1/' | \
            while read -r sys; do
                [ -z "$sys" ] && continue
                mkdir -p "${SCREENSHOTS_ROOT}/${sys}"
                CFG="${ROMS_ROOT}/${sys}/.retroarch.cfg"
                if [ ! -f "${CFG}" ]; then
                    mkdir -p "${ROMS_ROOT}/${sys}"
                    printf 'screenshot_directory = "%s/%s"\n' "${SCREENSHOTS_ROOT}" "${sys}" > "${CFG}"
                    # 전역 input_player1_analog_dpad_mode=1(좌 아날로그) 기본값은
                    # 8/10버튼 패드 기반 시스템 전용 — PSX/PC류(자체 아날로그
                    # 스틱 또는 방향키 그대로가 자연스러움)는 여기서 꺼둠(2026-07-05)
                    case "${sys}" in
                        psx|pc|scummvm|pc88|pc98)
                            printf 'input_player1_analog_dpad_mode = "0"\n' >> "${CFG}"
                            ;;
                    esac
                    # psx DualShock 지정(input_libretro_device_p1=517)은 여기서 정적으로
                    # 쓰지 않음 - 애초에 이 키는 일반 .cfg/appendconfig에서는 안 읽히고
                    # RetroArch의 리맵(.rmp) 파일에서만 파싱됨(2026-07-09 소스 확인).
                    # rpui-launcher.py의 write_pad_type_remap()이 코어 실행마다
                    # ~/.config/retroarch/config/remaps/{코어}/{코어}.rmp에 직접 씀.
                    logger -t "${TAG}" "screenshot cfg 생성: ${sys}"
                fi
            done
        fi

        # exFAT는 새 파일 생성 시 디렉토리 메타데이터가 즉시 디스크에 기록되지 않아
        # 재부팅 후 파일이 사라질 수 있음. 첫 부팅 파일 복사 후 전체 sync로 flush.
        sync

        # 설정 적용 (retropangui.conf → retroarch.cfg, es_settings.cfg)
        # 최초 부팅이거나 conf.default에서 새 키가 병합된 경우에만 실행한다.
        # 매 부팅마다 실행하면 사용자가 ES/RA에서 직접 변경한 설정이 덮어씌워진다.
        if [ "${APPLY_NEEDED}" = "true" ]; then
            if [ -x "${APPLY_SCRIPT}" ]; then
                "${APPLY_SCRIPT}" "${CONF_USER}"
            else
                logger -t "${TAG}" "apply 스크립트 없음: ${APPLY_SCRIPT}"
            fi
        fi

        # [하드웨어 고정] input_driver=udev, input_joypad_driver=udev 강제 적용.
        # - input_driver: KMS/DRM 환경에서 VT 없어 linuxraw 키보드 KDSKBMODE ioctl 실패
        # - input_joypad_driver: udev는 /dev/input/eventX 직접 접근, EV_FF(진동) 지원.
        # apply_retropangui_conf.sh 이후에 실행해 conf 값을 덮어씀.
        if [ -f "${RA_CFG_USER}" ]; then
            sed -i 's/^input_driver = .*/input_driver = "udev"/' "${RA_CFG_USER}"
            grep -q "^input_driver" "${RA_CFG_USER}" || \
                echo 'input_driver = "udev"' >> "${RA_CFG_USER}"
            sed -i 's/^input_joypad_driver = .*/input_joypad_driver = "udev"/' "${RA_CFG_USER}"
            grep -q "^input_joypad_driver" "${RA_CFG_USER}" || \
                echo 'input_joypad_driver = "udev"' >> "${RA_CFG_USER}"
        fi

        ;;
    stop)
        ;;
    restart|reload)
        "$0" start
        ;;
    *)
        echo "Usage: $0 {start|stop|restart}"
        exit 1
        ;;
esac

exit 0
