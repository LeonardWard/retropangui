#!/bin/sh
# S61share - Share 파티션(exFAT) 포맷 및 마운트

TAG="S61share"

BOOT_PART=$(awk '$2 == "/boot" {print $1; exit}' /proc/mounts)
if [ -n "${BOOT_PART}" ]; then
    DEVICE=$(echo "${BOOT_PART}" | sed 's/p[0-9]*$//')
else
    ROOT_PART=$(awk '$2 == "/" && $1 != "rootfs" && $1 != "overlay" {print $1; exit}' /proc/mounts)
    [ -z "${ROOT_PART}" ] && ROOT_PART=$(tr ' ' '\n' < /proc/cmdline | grep '^root=' | sed 's/root=//')
    DEVICE=$(echo "${ROOT_PART}" | sed 's/p[0-9]*$//')
fi
SHARE_MOUNT="/retropangui/share"

find_share_part() {
    local dev_name
    dev_name=$(basename "${DEVICE}")
    awk '{print $4}' /proc/partitions | \
        grep "^${dev_name}p" | \
        grep -vE "p1$|p2$" | \
        head -1 | \
        sed 's|^|/dev/|'
}

case "$1" in
    start)
        mkdir -p "${SHARE_MOUNT}"

        SHARE_PART=$(find_share_part)
        if [ -z "${SHARE_PART}" ] || [ ! -b "${SHARE_PART}" ]; then
            logger -t "${TAG}" "p3 없음 — initramfs에서 생성 실패"
            exit 1
        fi

        FS_TYPE=$(blkid -o value -s TYPE "${SHARE_PART}" 2>/dev/null || true)
        if [ "${FS_TYPE}" != "exfat" ]; then
            logger -t "${TAG}" "exFAT 포맷 중: ${SHARE_PART}"
            mkfs.exfat -n "share" "${SHARE_PART}"
            logger -t "${TAG}" "포맷 완료"
        fi

        if ! grep -q "${SHARE_MOUNT}" /proc/mounts; then
            mount -t exfat -o uid=0,gid=0,fmask=0022,dmask=0022,sync,dirsync \
                "${SHARE_PART}" "${SHARE_MOUNT}" || {
                logger -t "${TAG}" "마운트 실패: ${SHARE_PART}"
                exit 1
            }
            mkdir -p \
                "${SHARE_MOUNT}/roms/nes" \
                "${SHARE_MOUNT}/roms/snes" \
                "${SHARE_MOUNT}/roms/psx" \
                "${SHARE_MOUNT}/bios" \
                "${SHARE_MOUNT}/saves" \
                "${SHARE_MOUNT}/screenshots" \
                "${SHARE_MOUNT}/music" \
                "${SHARE_MOUNT}/system/emulationstation"
            SENTINEL="${SHARE_MOUNT}/.bundled_initialized"
            if [ ! -f "${SENTINEL}" ]; then
                BUNDLED="/usr/share/retropangui/bundled-roms"
                if [ -d "${BUNDLED}" ]; then
                    for sys in nes snes; do
                        [ -d "${BUNDLED}/${sys}" ] && \
                            cp -n "${BUNDLED}/${sys}"/* "${SHARE_MOUNT}/roms/${sys}/" 2>/dev/null || true
                    done
                fi
                BGMUSIC="/usr/share/retropangui/bundled-bgmusic"
                [ -d "${BGMUSIC}" ] && \
                    cp -n "${BGMUSIC}"/* "${SHARE_MOUNT}/music/" 2>/dev/null || true
                touch "${SENTINEL}"
            fi
            logger -t "${TAG}" "마운트 완료: ${SHARE_MOUNT} (${SHARE_PART})"
        fi
        ;;
    stop)
        umount "${SHARE_MOUNT}" 2>/dev/null || true
        ;;
    restart|reload)
        "$0" stop
        "$0" start
        ;;
    *)
        echo "Usage: $0 {start|stop|restart}"
        exit 1
        ;;
esac

exit 0
