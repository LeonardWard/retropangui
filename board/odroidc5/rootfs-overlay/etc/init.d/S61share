#!/bin/sh
# S61share - Share 파티션 마운트
#
# /boot/retropangui-boot.conf 의 sharedevice로 파티션 결정:
#   sharedevice=INTERNAL          → 내부 eMMC p3
#   sharedevice=DEV UUID=xxxx     → UUID로 특정 파티션
# 설정 없음 → 첫 부팅으로 간주, 내부 p3 exFAT 포맷 후 INTERNAL 기록
#
# 첫 부팅 이후에는 포맷 절대 없음. 마운트 실패 시 내부 p3 fallback.
#
# NAS 네트워크 마운트 (2026-07-10, Batocera/Recalbox 레퍼런스 기반 설계):
#   sharenetwork_<nfs|smb|cmd>=<SHARE|ROMS|SAVES|BIOS|MUSIC|SCREENSHOTS>@host:경로[:옵션]
#   sharenetwork_cmd=<mount 명령 그대로>
#   sharewait=<초>  (기본 20, 네트워크 대기 + 마운트 재시도 둘 다에 적용)
# Recalbox 실제 구현을 그대로 참고: sharedevice 값과 무관하게 위 디렉티브가
# 있으면 항상 실행됨(INTERNAL/DEV UUID 마운트가 먼저 끝난 뒤, 그 위에 개별
# 대상만 네트워크로 덮어씀) - 이미 마운트된 base 위에 subdir 단위로 겹쳐
# 마운트하거나, SHARE 전체를 대상으로 지정하면 통째로 대체됨.

TAG="S61share"
SHARE_MOUNT="/retropangui/share"
BOOT_CONF="/boot/retropangui-boot.conf"
MOUNT_OPTS="uid=0,gid=0,fmask=0022,dmask=0022,sync,dirsync"
NETLOG="/tmp/retropangui-share-network.log"

# 내부 eMMC 디바이스 경로 반환 (예: /dev/mmcblk0)
get_internal_device() {
    local part
    part=$(awk '$2 == "/boot" {print $1; exit}' /proc/mounts)
    if [ -z "${part}" ]; then
        part=$(awk '$2 == "/" && $1 != "rootfs" && $1 != "overlay" {print $1; exit}' /proc/mounts)
        [ -z "${part}" ] && part=$(tr ' ' '\n' < /proc/cmdline | grep '^root=' | sed 's/root=//')
    fi
    echo "${part}" | sed 's/p[0-9]*$//'
}

# 내부 eMMC p3 파티션 경로 반환 (예: /dev/mmcblk0p3)
find_internal_part() {
    local dev_name
    dev_name=$(basename "$(get_internal_device)")
    awk '{print $4}' /proc/partitions | \
        grep "^${dev_name}p" | \
        grep -vE "p1$|p2$" | \
        head -1 | \
        sed 's|^|/dev/|'
}

# UUID로 블록 디바이스 경로 반환
find_dev_by_uuid() {
    local uuid="$1"
    local link="/dev/disk/by-uuid/${uuid}"
    [ -L "${link}" ] && readlink -f "${link}" || true
}

# boot.conf에서 sharedevice 값 읽기
read_sharedevice() {
    grep "^sharedevice=" "${BOOT_CONF}" 2>/dev/null | cut -d= -f2- | tr -d ' \r'
}

# boot.conf에 sharedevice 기록. 파일이 아직 없으면(최초 부팅) 사용법 주석
# 헤더까지 같이 써줌 - PC로 부팅 파티션(FAT32) 열어보거나 SSH로 파일을 직접
# 봤을 때 문법을 바로 알 수 있게. storage-mgr(C, storage_mgr.c)이 나중에
# sharedevice= 줄만 골라서 교체하며 이 주석들은 그대로 보존함 - 단
# storage_mgr.c의 파일 버퍼가 줄 수 제한이 있어서(현재 64줄) 헤더를
# 너무 길게 늘리지 말 것(2026-07-11).
write_sharedevice() {
    local val="$1"
    if grep -q "^sharedevice=" "${BOOT_CONF}" 2>/dev/null; then
        sed -i "s|^sharedevice=.*|sharedevice=${val}|" "${BOOT_CONF}"
    else
        cat > "${BOOT_CONF}" <<'EOF'
# retropangui-boot.conf - share 파티션 / 네트워크 공유 설정
#
# sharedevice=INTERNAL        내부 저장장치(eMMC) 사용 - 기본값
# sharedevice=NETWORK         내부 대신 쓴다는 뜻이 아니라 그냥 INTERNAL과
#                              동일하게 처리됨(Batocera/Recalbox 문서에서
#                              흔히 이렇게 적길래 호환용으로 인식만 함) -
#                              네트워크 공유 여부는 아래 sharenetwork_* 줄이
#                              있는지 없는지로만 결정됨
# sharedevice=DEV UUID=xxxx   UUID로 지정한 외부 파티션 사용
#                              (마운트 실패 시 자동으로 INTERNAL로 폴백)
#
# 네트워크(NAS/공유폴더) 마운트 - sharedevice 값과 무관하게 아래 sharenetwork_*
# 줄이 있으면 항상 적용됨(내부/외부 마운트가 끝난 자리 위에, 지정한 대상만
# 개별적으로 네트워크 공유로 덮어씀):
#   문법: sharenetwork_<smb|nfs><번호>=<대상>@<IP>:<경로>[:마운트옵션]
#   <대상> 자리: SHARE(전체) | ROMS | SAVES | BIOS | MUSIC | SCREENSHOTS
#   번호(1,2,3...)는 여러 개를 동시에 쓸 때 구분용 - 하나만 쓸 거면 번호 없이
#   sharenetwork_smb=... 로도 됨
#   SMB 계정 없이 게스트로 붙는 공유면 username=...,password=... 대신 guest
#   smb/nfs 문법으로 안 되는 특수한 경우는 sharenetwork_cmd=<mount 명령 그대로>
#   sharewait=20   네트워크 대기/마운트 재시도 시간(초) - 생략 시 기본 20초
#
# 아래는 실제로 동작하는 예시 - 쓰고 싶은 줄 앞의 #만 지우고 IP/경로/계정을
# 실제 값으로 바꾸면 됨 (안 쓸 줄은 # 그대로 둬서 비활성 상태 유지):
#
#sharewait=30
#sharenetwork_smb1=ROMS@192.168.1.112:share/roms:username=USER,password=PASS,vers=3.0
#sharenetwork_smb2=SAVES@192.168.1.112:share/saves:username=USER,password=PASS,vers=3.0
#sharenetwork_smb3=BIOS@192.168.1.112:share/bios:username=USER,password=PASS,vers=3.0
#sharenetwork_smb4=SCREENSHOTS@192.168.1.112:share/screenshots:username=USER,password=PASS,vers=3.0
#sharenetwork_nfs1=ROMS@192.168.1.112:/mnt/share/roms
#
EOF
        echo "sharedevice=${val}" >> "${BOOT_CONF}"
    fi
    sync
}

# exFAT 마운트 시도
try_mount() {
    local dev="$1"
    mount -t exfat -o "${MOUNT_OPTS}" "${dev}" "${SHARE_MOUNT}" 2>/dev/null
}

# boot.conf에서 sharewait 값 읽기 (없으면 기본 20초)
read_sharewait() {
    local v
    v=$(grep "^sharewait=" "${BOOT_CONF}" 2>/dev/null | cut -d= -f2- | tr -d ' \r')
    echo "${v:-20}"
}

# 네트워크(게이트웨이 또는 8.8.8.8) 응답 대기 — 최대 ${1}초, 1초 간격
wait_for_network() {
    local maxwait="$1" i=0
    local gw
    gw=$(ip route show default 2>/dev/null | awk '/default/ {print $3; exit}')
    while [ "${i}" -lt "${maxwait}" ]; do
        if [ -n "${gw}" ] && ping -c1 -W1 "${gw}" >/dev/null 2>&1; then
            return 0
        fi
        ping -c1 -W1 8.8.8.8 >/dev/null 2>&1 && return 0
        sleep 1
        i=$((i + 1))
    done
    return 1
}

# sharenetwork_<type>=<directive> 하나 처리
#   type: nfs | smb | cmd (뒤에 붙는 숫자는 무시 - smb0/smb1처럼 여러 개 허용)
#   nfs/smb 포맷: <SHARE|ROMS|SAVES|BIOS|MUSIC|SCREENSHOTS>@host:경로[:마운트옵션]
#   cmd 포맷: mount 명령 그대로
# 반환값: 0=성공, 1=실패(재시도 대상), 2=입력 오류(재시도 안 함)
# target 키워드(SHARE/ROMS/SAVES/BIOS/MUSIC/SCREENSHOTS) → 마운트포인트 경로.
# mount/umount 양쪽에서 재사용 - 대소문자 안 가림(2026-07-11 이유는 아래 유지).
# 실패 시 아무것도 echo 안 하고 return 1.
_network_target_mountpoint() {
    local target="$1"
    case "${target}" in
        SHARE)       echo "${SHARE_MOUNT}" ;;
        ROMS)        echo "${SHARE_MOUNT}/roms" ;;
        SAVES)       echo "${SHARE_MOUNT}/saves" ;;
        BIOS)        echo "${SHARE_MOUNT}/bios" ;;
        MUSIC)       echo "${SHARE_MOUNT}/music" ;;
        SCREENSHOTS) echo "${SHARE_MOUNT}/screenshots" ;;
        *)           return 1 ;;
    esac
}

mount_network_directive() {
    local rawtype="$1" directive="$2"
    local directiveType target remoteHost remotePath mountOptions mountPoint cmd

    directiveType=$(echo "${rawtype}" | sed -r 's/[0-9]+$//')

    if [ "${directiveType}" = "cmd" ]; then
        cmd="${directive}"
    else
        target=$(echo "${directive}" | sed -r 's|^([^@]+)@.*|\1|' | tr '[:lower:]' '[:upper:]')
        remoteHost=$(echo "${directive}" | sed -r 's|^[^@]+@([^:]+):.*|\1|')
        remotePath=$(echo "${directive}" | sed -r 's|^[^@]+@[^:]+:([^:]*).*|\1|')
        mountOptions=$(echo "${directive}" | sed -r 's|^[^@]+@[^:]+:[^:]*:?(.*)|\1|')

        # 대상 키워드는 대소문자 안 가림(roms/Roms/ROMS 다 허용) - 실제로
        # 소문자로 적어서 조용히 거부당하는 사용자가 있어서 2026-07-11 추가.
        # 호스트/경로/mount 옵션은 원래 대소문자 그대로 유지(계정명 등에
        # 대소문자가 의미 있을 수 있어서 여긴 안 건드림).
        mountPoint=$(_network_target_mountpoint "${target}")
        if [ -z "${mountPoint}" ]; then
            echo "잘못된 대상 '${target}' - sharenetwork_${rawtype}=${directive} 무시" >> "${NETLOG}"
            return 2
        fi

        case "${directiveType}" in
            nfs)
                # 클래식 NFSv3 클라이언트 마운트 - busybox mount의 NFS 지원 여부와
                # 무관하도록 mount.nfs 헬퍼(nfs-utils)를 직접 호출
                #
                # 2026-07-16: nfs/nfsv4 커널 모듈이 기본 상태에서 로드돼있지
                # 않아 실기기 검증 중 "No such device"로 실패했음(modprobe
                # 안 하면 항상 재현). nfsv4는 nfs와 별개 모듈이라 한 줄에
                # 같이 modprobe해도 nfsv4만 안 실리는 현상이 있어(실기기
                # 확인) 반드시 각각 개별 호출해야 함 - vers=4.x를 쓰는
                # NAS(시놀로지 등)는 nfsv4 없이는 "Protocol not supported"로
                # 실패함. 실패해도(이미 로드됐거나 built-in인 커널이면 에러)
                # 무시하고 진행.
                modprobe nfs 2>/dev/null || true
                modprobe nfsv4 2>/dev/null || true
                local opts="port=2049,nolock,proto=tcp"
                [ -n "${mountOptions}" ] && opts="${opts},${mountOptions}"
                cmd="mkdir -p ${mountPoint} && mount.nfs -o ${opts} ${remoteHost}:${remotePath} ${mountPoint}"
                ;;
            smb)
                local smbopts=""
                [ -n "${mountOptions}" ] && smbopts="-o ${mountOptions}"
                cmd="mkdir -p ${mountPoint} && mount.cifs ${smbopts} //${remoteHost}/${remotePath} ${mountPoint}"
                ;;
            *)
                echo "잘못된 디렉티브 타입 '${directiveType}' - sharenetwork_${rawtype}=${directive} 무시" >> "${NETLOG}"
                return 2
                ;;
        esac
    fi

    echo "${cmd}" >> "${NETLOG}"
    eval "${cmd}" >> "${NETLOG}" 2>&1
}

# boot.conf의 모든 sharenetwork_* 디렉티브 처리 (없으면 즉시 종료 - 네트워크
# 대기로 인한 부팅 지연 없음). sharedevice 값과 무관하게 항상 실행됨 -
# INTERNAL/DEV UUID로 이미 마운트된 위 자리에 지정된 대상만 개별 덮어씀.
mount_network_shares() {
    local directives
    directives=$(sed -nr 's/^sharenetwork_([^=]+)=(.*)$/\1\t\2/p' "${BOOT_CONF}" 2>/dev/null)
    [ -z "${directives}" ] && return 0

    local maxwait
    maxwait=$(read_sharewait)

    logger -t "${TAG}" "sharenetwork_* 디렉티브 발견 - 네트워크 대기(최대 ${maxwait}초)"
    if ! wait_for_network "${maxwait}"; then
        logger -t "${TAG}" "네트워크 대기 시간 초과 - 네트워크 공유 마운트 스킵"
        return 1
    fi

    echo "${directives}" | while IFS="$(printf '\t')" read -r rawtype directive; do
        [ -z "${rawtype}" ] && continue
        local retry="${maxwait}"
        while [ "${retry}" -gt 0 ]; do
            mount_network_directive "${rawtype}" "${directive}"
            local rc=$?
            if [ "${rc}" = "0" ] || [ "${rc}" = "2" ]; then
                break
            fi
            retry=$((retry - 1))
            sleep 1
        done
        if [ "${rc}" = "0" ]; then
            logger -t "${TAG}" "네트워크 공유 마운트 완료: sharenetwork_${rawtype}"
        else
            logger -t "${TAG}" "네트워크 공유 마운트 실패: sharenetwork_${rawtype} (로그: ${NETLOG})"
        fi
    done
}

# 2026-07-16: 네트워크 공유(nfs/cifs) 마운트를 네트워크 인터페이스가 아직
# 살아있는 시점에 먼저 해제하기 위한 전용 함수 - S67rpui-network-unmount가
# 종료 시퀀스 중 S64rpui-wifi(WiFi 링크를 실제로 끊음)보다 먼저 호출함.
# 실기기에서 재부팅이 "nfs: server ... not responding, timed out"로
# 무한정 멈추는 사고가 있었음 - 원인: rcK가 S 번호 역순으로 정지시키는데
# S64rpui-wifi가 S61share보다 먼저 정지되면서 WiFi 연결이 끊긴 뒤에야
# S61share stop이 NFS umount를 시도했고, hard 마운트(의도적으로 유지 -
# 원격 NAS 응답이 일시적으로 늦어도 데이터 정합성을 우선하기로 결정)라
# 서버 무응답 시 영원히 재시도하며 대기했음.
#
# Recalbox(S11share stop) 구현을 참고해 boot.conf 파싱이 아니라 실제
# /proc/mounts 상태 기준으로 처리 - boot.conf 문법과 무관하게 그 시점에
# 실제로 걸려있는 네트워크 마운트를 전부 잡아내고, fuser로 열린 파일
# 핸들부터 정리한 뒤 타입 단위로 일괄 umount함(개별 마운트포인트를
# boot.conf에서 역산하는 것보다 견고함). Recalbox는 "nfs cifs"만 훑는데
# 이 프로젝트는 NFSv4.1을 쓰므로 /proc/mounts에 타입이 "nfs4"로 찍힘
# (실기기 확인) - 빠뜨리면 이 함수가 하나 마나이므로 반드시 포함.
umount_network_shares() {
    local fstype fs_dir
    for fstype in nfs nfs4 cifs; do
        awk -v t="${fstype}" '$3 == t { print $2 }' /proc/mounts | while read -r fs_dir; do
            # 열린 파일 핸들 보유 프로세스 정리: SIGTERM 먼저(정상 종료 기회),
            # 그래도 남아있으면 SIGKILL - Recalbox의 kill_process_from_dir와 동일 패턴
            fuser -s -m -k -15 "${fs_dir}" 2>/dev/null && sleep 1
            fuser -s -m -k -9  "${fs_dir}" 2>/dev/null
        done
        # 타입 단위 일괄 umount. -f(force)는 busybox 도움말에 "unreachable
        # NFS server" 대응용으로 명시돼 있음 - fuser 정리 후에도 커널에
        # pending RPC가 남아있는 경우까지 대비.
        umount -a -t "${fstype}" 2>>"${NETLOG}" || umount -a -t "${fstype}" -f 2>>"${NETLOG}" || true
    done
    logger -t "${TAG}" "네트워크 공유 선제 언마운트 완료(nfs/nfs4/cifs)"
}

# 단일 파일 다운로드 — 실패하거나 0바이트이면 파일 삭제
_rp_dl() {
    local dst="$1" url="$2"
    mkdir -p "$(dirname "${dst}")"
    if wget -q -T 30 --no-check-certificate -O "${dst}" "${url}" 2>/dev/null; then
        [ -s "${dst}" ] || rm -f "${dst}"
    else
        rm -f "${dst}"
    fi
}

# 추가 ROM 백그라운드 다운로드 — 최초 부팅 1회, 실패 시 묵묵히 스킵
# 소스: 리콜박스 GitLab raw (CC BY-NC-SA / GPL / 공식 freeware)
download_extra_roms() {
    # 네트워크 대기 (최대 60초)
    local i=0
    while [ $i -lt 60 ]; do
        ping -c1 -W2 8.8.8.8 >/dev/null 2>&1 && break
        sleep 2
        i=$((i+2))
    done
    ping -c1 -W2 8.8.8.8 >/dev/null 2>&1 || return 0

    local roms="${SHARE_MOUNT}/roms"
    local base="https://gitlab.com/recalbox/recalbox/-/raw/master/package/recalbox-romfs2/systems"

    # 2026-07-15: 게임별 폴더로 배치(todo-20260714-bundled-game-curation) -
    # 큐레이션 단계에서 같은 폴더에 gamelist.xml/이미지를 동봉하기 위한 준비.

    # Mega Drive — Retrosouls (CC BY-NC-SA 4.0)
    local md="${roms}/megadrive"
    _rp_dl "${md}/Yazzie (Retrosouls)/Yazzie (Retrosouls).bin" \
        "${base}/megadrive/init/roms/Yazzie%20(Retrosouls).bin"
    _rp_dl "${md}/Gluf (Retrosouls)/Gluf (Retrosouls).bin" \
        "${base}/megadrive/init/roms/Gluf%20(Retrosouls).bin"
    _rp_dl "${md}/Old Towers (Retrosouls)/Old Towers (Retrosouls).bin" \
        "${base}/megadrive/init/roms/Old%20Towers%20(Retrosouls).bin"
    _rp_dl "${md}/Misplaced (Retrosouls)/Misplaced (Retrosouls).bin" \
        "${base}/megadrive/init/roms/Misplaced%20(Retrosouls).bin"

    # MSX1 — GPL + CC BY-NC-SA
    local m1="${roms}/msx1"
    _rp_dl "${m1}/xracing/xracing.rom"               "${base}/msx1/init/roms/xracing.rom"
    _rp_dl "${m1}/xspelunker-en/xspelunker-en.rom"   "${base}/msx1/init/roms/xspelunker-en.rom"
    _rp_dl "${m1}/Yazzie/Yazzie.rom"                 "${base}/msx1/init/roms/Yazzie.rom"

    # MSX2 — Retroworks (비상업 재배포 가능)
    local m2="${roms}/msx2"
    _rp_dl "${m2}/Brunilda [v1.1] (Retroworks)/Brunilda [v1.1] (Retroworks).rom" \
        "${base}/msx2/init/roms/Brunilda%20%5Bv1.1%5D%20(Retroworks).rom"
    _rp_dl "${m2}/The Sword of Ianna (Retroworks)/The Sword of Ianna (Retroworks).rom" \
        "${base}/msx2/init/roms/The%20Sword%20of%20Ianna%20(Retroworks).rom"

    # ScummVM — 공식 freeware. Recalbox 소스가 이미 "게임명.scummvm/" 폴더 안에
    # raw 게임 데이터를 담고 있어서 그대로 받으면 코어의 폴더 자동 감지
    # (todo-core-lr-scummvm 문서의 "게임 배치법" 참조)가 그대로 먹힘 -
    # 예전처럼 게임ID 텍스트 파일을 별도로 만들 필요 없음.
    local sc="${roms}/scummvm"

    # Beneath a Steel Sky
    local sky="${sc}/Beneath a Steel Sky (English).scummvm"
    _rp_dl "${sky}/sky.dnr" \
        "${base}/scummvm/init/roms/Beneath%20a%20Steel%20Sky%20(English).scummvm/sky.dnr"
    _rp_dl "${sky}/sky.dsk" \
        "${base}/scummvm/init/roms/Beneath%20a%20Steel%20Sky%20(English).scummvm/sky.dsk"

    # Flight of the Amazon Queen
    local queen="${sc}/Flight of the Amazon Queen (English).scummvm"
    _rp_dl "${queen}/queen.1" \
        "${base}/scummvm/init/roms/Flight%20of%20the%20Amazon%20Queen%20(English).scummvm/queen.1"

    # Soltys
    local soltys="${sc}/Soltys (English).scummvm"
    _rp_dl "${soltys}/vol.cat" \
        "${base}/scummvm/init/roms/Soltys%20(English).scummvm/vol.cat"
    _rp_dl "${soltys}/vol.dat" \
        "${base}/scummvm/init/roms/Soltys%20(English).scummvm/vol.dat"

    # Lure of the Temptress
    local lure="${sc}/Lure of the Tempress (English).scummvm"
    for f in Disk1.vga Disk2.vga Disk3.vga Disk4.vga Lure.exe; do
        _rp_dl "${lure}/${f}" \
            "${base}/scummvm/init/roms/Lure%20of%20the%20Tempress%20(English).scummvm/${f}"
    done

    # 2026-07-16: sky.cpt/lure.dat - 게임 배포 파일이 아니라 ScummVM 자체
    # "엔진 추가 데이터"(engines/sky, engines/lure 코드가 런타임에 읽는
    # 리소스). 공식 scummvm/scummvm 저장소 dists/engine-data/에 있음 -
    # scummvm.ini의 extrapath=share/bios/scummvm/extra (MT32 ROM과 같은
    # 폴더) - share/bios/scummvm/ 루트에 넣으면 코어가 못 찾음(실기기로
    # 확인된 실수 - 처음엔 루트에 넣었다가 안 돼서 extra/로 옮김).
    local scbios="${SHARE_MOUNT}/bios/scummvm/extra"
    _rp_dl "${scbios}/sky.cpt" \
        "https://raw.githubusercontent.com/scummvm/scummvm/master/dists/engine-data/sky.cpt"
    _rp_dl "${scbios}/lure.dat" \
        "https://raw.githubusercontent.com/scummvm/scummvm/master/dists/engine-data/lure.dat"

    # 2026-07-15: 박스아트/스크린샷 - 저장소에 이미지 바이너리를 커밋하지
    # 않고 원 배포처에서 받아온다("임시로" 코드 다운로드 방식, 이미지 검토
    # 후 URL이 교체될 수 있음 - todo-20260714-bundled-game-curation).
    local rbase="https://gitlab.com/recalbox/recalbox/-/raw/master/package/recalbox-romfs2/systems"
    _rp_dl "${md}/Yazzie (Retrosouls)/image.png"       "${rbase}/megadrive/init/roms/media/images/Yazzie%20(Retrosouls).png"
    _rp_dl "${md}/Gluf (Retrosouls)/image.png"         "${rbase}/megadrive/init/roms/media/images/Gluf%20(Retrosouls).png"
    _rp_dl "${md}/Old Towers (Retrosouls)/image.png"   "${rbase}/megadrive/init/roms/media/images/Old%20Towers%20(Retrosouls).png"
    _rp_dl "${md}/Misplaced (Retrosouls)/image.png"    "${rbase}/megadrive/init/roms/media/images/Misplaced%20(Retrosouls).png"
    _rp_dl "${m1}/xracing/image.png"                   "${rbase}/msx1/init/roms/media/images/xracing.png"
    _rp_dl "${m1}/xspelunker-en/image.png"              "${rbase}/msx1/init/roms/media/images/xspelunker-en.png"
    _rp_dl "${m1}/Yazzie/image.png"                     "${rbase}/msx1/init/roms/media/images/Yazzie.png"
    _rp_dl "${m2}/Brunilda [v1.1] (Retroworks)/image.png" \
        "${rbase}/msx2/init/roms/media/images/Brunilda%20%5Bv1.1%5D%20(Retroworks).png"
    _rp_dl "${m2}/The Sword of Ianna (Retroworks)/image.png" \
        "${rbase}/msx2/init/roms/media/images/The%20Sword%20of%20Ianna%20(Retroworks).png"
    _rp_dl "${sky}/image.png"   "${rbase}/scummvm/init/roms/media/images/Beneath%20a%20Steel%20Sky%20(English).png"
    _rp_dl "${queen}/image.png" "${rbase}/scummvm/init/roms/media/images/Flight%20of%20the%20Amazon%20Queen%20(Fran%C3%A7ais).png"
    _rp_dl "${soltys}/image.png" "${rbase}/scummvm/init/roms/media/images/Soltys%20(English).png"
    _rp_dl "${lure}/image.png"  "${rbase}/scummvm/init/roms/media/images/Lure%20of%20the%20Tempress%20(Fran%C3%A7ais).png"

    # 큐레이션한 gamelist.xml(전체 필드) 최초 1회만 배치 - 이미 있으면
    # 건드리지 않음(사용자가 직접 스크랩/수정한 내용 보존).
    for sys in megadrive msx1 msx2 scummvm; do
        tmpl="/usr/share/retropangui/bundled-roms/${sys}/gamelist.xml"
        dst="${roms}/${sys}/gamelist.xml"
        [ -f "${tmpl}" ] && [ ! -f "${dst}" ] && cp "${tmpl}" "${dst}"
    done
}

# 폴더 구조 초기화 + bundled 파일 복사 (sentinel로 최초 1회만)
init_share_dirs() {
    mkdir -p \
        "${SHARE_MOUNT}/roms/nes" \
        "${SHARE_MOUNT}/roms/snes" \
        "${SHARE_MOUNT}/roms/psx" \
        "${SHARE_MOUNT}/roms/megadrive" \
        "${SHARE_MOUNT}/roms/sega32x" \
        "${SHARE_MOUNT}/roms/segacd" \
        "${SHARE_MOUNT}/roms/msx1" \
        "${SHARE_MOUNT}/roms/msx2" \
        "${SHARE_MOUNT}/roms/fds" \
        "${SHARE_MOUNT}/roms/scummvm" \
        "${SHARE_MOUNT}/roms/dos" \
        "${SHARE_MOUNT}/roms/utility" \
        "${SHARE_MOUNT}/bios" \
        "${SHARE_MOUNT}/bios/music" \
        "${SHARE_MOUNT}/music" \
        "${SHARE_MOUNT}/saves" \
        "${SHARE_MOUNT}/screenshots" \
        "${SHARE_MOUNT}/system/emulationstation"

    # bundled-bios: 파일 단위로 없는 것만 복사 (sentinel 무관, OTA로 추가되면 자동 반영)
    #
    # 2026-07-14: "cp -rn SRC/. DST/" 방식은 이 BusyBox(v1.36.1)에서 DST에
    # 이미 다른 내용이 하나라도 있으면 SRC의 새 최상위 항목을 통째로
    # 무시하는 버그가 있음(에러 없이 exit 0, 실기기에서 무관한 디렉토리로도
    # 재현 확인) - share/bios는 최초 부팅 때부터 파일이 많아서 그 이후
    # bundled-bios에 추가된 내용(scummvm 테마 등)이 전부 조용히 누락되고
    # 있었음. find로 파일 단위 순회하며 없는 파일만 개별 복사하는 방식으로
    # 교체(디렉토리는 필요할 때만 mkdir -p).
    local bundled_bios="/usr/share/retropangui/bundled-bios"
    if [ -d "${bundled_bios}" ]; then
        find "${bundled_bios}" -type f | while IFS= read -r src; do
            rel="${src#${bundled_bios}/}"
            dst="${SHARE_MOUNT}/bios/${rel}"
            [ -f "${dst}" ] && continue
            mkdir -p "$(dirname "${dst}")"
            cp "${src}" "${dst}"
        done
    fi

    # bundled-bgmusic(.mid): 위 bundled-bios와 같은 이유로 sentinel 밖으로 뺌
    # (2026-07-14) - 예전엔 최초 부팅 1회만 복사했는데, share/music →
    # share/bios/music 경로 이전 이후 이미 초기화 끝난 기기에서는 sentinel이
    # 이미 있어 새 경로로 재복사가 영영 안 일어나는 버그였음(실기기 확인 -
    # ES 배경음악 켜도 재생 안 됨, share/bios/music 폴더가 빈 채로 남아있었음).
    #
    # 2026-07-16: share/bios/music은 사운드폰트(.sf2)·MT-32 롬 전용 폴더로
    # bios/music 이전은 설계 오류였음(실제 재생곡을 합성 재료 폴더에 두는 게
    # 잘못됨, 사용자 지적) - 번들 .mid 복사 대상을 share/music으로 되돌림.
    local bgmusic="/usr/share/retropangui/bundled-bgmusic"
    if [ -d "${bgmusic}" ]; then
        cp -n "${bgmusic}"/* "${SHARE_MOUNT}/music/" 2>/dev/null || true
    fi

    local sentinel="${SHARE_MOUNT}/.bundled_initialized"
    if [ ! -f "${sentinel}" ]; then
        command -v rpui-bundlegame >/dev/null 2>&1 && rpui-bundlegame init
        touch "${sentinel}"
        download_extra_roms &
    fi
}

case "$1" in
    start)
        mkdir -p "${SHARE_MOUNT}"
        grep -q " ${SHARE_MOUNT} " /proc/mounts && exit 0

        SHAREDEV=$(read_sharedevice)
        INTERNAL_PART=$(find_internal_part)
        MOUNTED=false

        if [ -z "${SHAREDEV}" ]; then
            # ── 초기화 미완료: share 없으면 포맷, 있으면 그대로 사용 ──
            if [ -b "${INTERNAL_PART}" ]; then
                if try_mount "${INTERNAL_PART}"; then
                    MOUNTED=true
                    write_sharedevice "INTERNAL"
                    logger -t "${TAG}" "내부 p3 마운트 완료 (기존 share): ${INTERNAL_PART}"
                else
                    logger -t "${TAG}" "내부 p3 share 없음 — exFAT 포맷 중: ${INTERNAL_PART}"
                    mkfs.exfat -n "share" "${INTERNAL_PART}"
                    if try_mount "${INTERNAL_PART}"; then
                        MOUNTED=true
                        write_sharedevice "INTERNAL"
                        logger -t "${TAG}" "내부 p3 포맷 후 마운트 완료: ${INTERNAL_PART}"
                    else
                        logger -t "${TAG}" "내부 p3 마운트 실패: ${INTERNAL_PART}"
                    fi
                fi
            else
                logger -t "${TAG}" "내부 p3 없음"
            fi

        elif [ "${SHAREDEV}" = "INTERNAL" ] || [ "${SHAREDEV}" = "NETWORK" ]; then
            # ── 내부 p3 마운트 ── (NETWORK도 여기로: Batocera/Recalbox 문서에
            # 흔히 sharedevice=NETWORK로 적혀있길래 그대로 붙여넣는 사용자가
            # 있을 수 있음 - 이 프로젝트는 sharenetwork_* 유무로 네트워크
            # 사용 여부를 판단하므로 NETWORK 값 자체엔 특별한 의미가 없음.
            # INTERNAL과 동일하게 처리해서 "DEV UUID=NETWORK" 같은 엉뚱한
            # 시도/로그가 안 남게 함, 2026-07-11)
            if [ -b "${INTERNAL_PART}" ] && try_mount "${INTERNAL_PART}"; then
                MOUNTED=true
                logger -t "${TAG}" "마운트 완료 (내부): ${INTERNAL_PART}"
            else
                logger -t "${TAG}" "내부 p3 마운트 실패 — share 없이 계속"
            fi

        else
            # ── 외부 장치: DEV UUID=xxxx ──
            UUID=$(echo "${SHAREDEV}" | sed 's/^DEV UUID=//')
            EXT_DEV=$(find_dev_by_uuid "${UUID}")

            if [ -b "${EXT_DEV}" ] && try_mount "${EXT_DEV}"; then
                MOUNTED=true
                logger -t "${TAG}" "마운트 완료 (UUID=${UUID}): ${EXT_DEV}"
            else
                # 외부 장치 없음/실패 → 내부 fallback
                logger -t "${TAG}" "외부 장치 마운트 실패 (UUID=${UUID}), 내부 fallback"
                if [ -b "${INTERNAL_PART}" ] && try_mount "${INTERNAL_PART}"; then
                    MOUNTED=true
                    logger -t "${TAG}" "Fallback 마운트 완료 (내부): ${INTERNAL_PART}"
                else
                    logger -t "${TAG}" "Fallback 마운트 실패 — share 없이 계속"
                fi
            fi
        fi

        if [ "${MOUNTED}" = "true" ]; then
            init_share_dirs
        fi

        # NAS 네트워크 마운트 — sharedevice 값과 무관하게 sharenetwork_* 디렉티브가
        # 있으면 항상 처리 (없으면 mount_network_shares가 바로 리턴, 지연 없음).
        # download_extra_roms()와 달리 백그라운드로 안 돌림 - ES(S99)가 스캔을
        # 시작하기 전에 NAS 콘텐츠가 자리에 있어야 하므로 동기적으로 대기
        # (Recalbox의 mountNetwork() 호출도 동일하게 블로킹) - sharenetwork_*
        # 디렉티브를 안 쓰는 사용자는 위에서 바로 리턴되니 부팅 지연 없음.
        mount_network_shares
        ;;

    stop)
        umount "${SHARE_MOUNT}" 2>/dev/null || true
        ;;

    # 2026-07-16: 종료 시퀀스에서 네트워크 인터페이스가 내려가기 전에
    # S67rpui-network-unmount가 호출하는 전용 서브커맨드 - 위 umount_network_shares
    # 설명 참고. 일반 stop과 분리한 이유: stop은 S61share 본연의 정지
    # 순서(S64rpui-wifi보다 늦음)에 그대로 두고, 네트워크 언마운트만
    # 시점을 앞당겨야 해서 별도 진입점이 필요했음.
    network-stop)
        umount_network_shares
        ;;

    restart|reload)
        "$0" stop
        "$0" start
        ;;

    *)
        echo "Usage: $0 {start|stop|restart}"
        exit 1
        ;;
esac

exit 0
