#!/bin/sh
# S99moonlightweb - moonlight-web-stream 데몬 (Sunshine 트래픽을 WebRTC로
# 브라우저에 중계하는 웹 서버 - 앱 설치 없이 브라우저로 원격 화면 접속)
#
# S99sunshine과 마찬가지로 원격 디버깅/확인용 도구 - 기본적으로 꺼져
# 있음(retropangui.conf의 system.remote_streaming=true일 때만 기동,
# 2026-07-16).

TAG="S99moonlightweb"
APP_DIR="/usr/share/retropangui/moonlight-web-stream"
DAEMON="${APP_DIR}/web-server"
PIDFILE="/run/moonlightweb.pid"
RP_CONF="/retropangui/share/system/retropangui.conf"
MWS_CONF_DIR="/root/.config/moonlight-web-stream"
MWS_CONF="${MWS_CONF_DIR}/config.json"

is_enabled() {
    [ -f "${RP_CONF}" ] || return 1
    val=$(grep -E "^system\.remote_streaming[[:space:]]*=" "${RP_CONF}" | tail -1 | sed 's/^[^=]*=//' | tr -d ' \r')
    [ "${val}" = "true" ]
}

case "$1" in
    start)
        if ! is_enabled; then
            logger -t "${TAG}" "비활성화됨(system.remote_streaming=false) - 건너뜀"
            exit 0
        fi
        [ -x "${DAEMON}" ] || { logger -t "${TAG}" "web-server 바이너리 없음, 건너뜀"; exit 0; }
        mkdir -p "${MWS_CONF_DIR}"

        # 첫 실행: 기본 설정 생성 후 data_storage.path만 쓰기 가능한 경로로
        # 수정 - 기본값 "server/data.json"은 실행 디렉토리(APP_DIR, squashfs
        # 읽기전용) 기준 상대경로라 그대로 두면 계정/페어링 저장이 실패함
        # (2026-07-16 실기기 확인).
        if [ ! -f "${MWS_CONF}" ]; then
            (cd "${APP_DIR}" && ./web-server --config-path "${MWS_CONF}" print-config > "${MWS_CONF}" 2>/dev/null)
            sed -i "s#\"path\": \"server/data.json\"#\"path\": \"${MWS_CONF_DIR}/data.json\"#" "${MWS_CONF}"
        fi

        logger -t "${TAG}" "시작"
        # streamer_path/static 등 상대경로 자산이 APP_DIR 기준이라 반드시 거기서
        # 실행 - 설정/데이터(config.json, data.json)는 --config-path로 쓰기
        # 가능한 /root/.config 쪽으로 분리(APP_DIR은 squashfs, 읽기전용).
        cd "${APP_DIR}" || exit 0
        # busybox start-stop-daemon엔 --chdir 옵션이 없음("unrecognized option")
        # - 위 cd로 이미 처리(background 포크는 부모 쉘의 CWD를 그대로 물려받음,
        # 2026-07-16 실기기에서 --chdir 넣었다가 조용히 실패해 확인).
        start-stop-daemon --start --quiet --background \
            --make-pidfile --pidfile "${PIDFILE}" \
            --exec "${DAEMON}" -- --config-path "${MWS_CONF}" run 2>&1 | logger -t "${TAG}"
        ;;
    stop)
        logger -t "${TAG}" "종료"
        start-stop-daemon --stop --quiet --pidfile "${PIDFILE}" --signal TERM
        rm -f "${PIDFILE}"
        ;;
    restart|reload)
        "$0" stop
        sleep 1
        "$0" start
        ;;
    *)
        echo "Usage: $0 {start|stop|restart}"
        exit 1
        ;;
esac

exit 0
