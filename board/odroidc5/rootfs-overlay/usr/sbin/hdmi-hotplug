#!/bin/sh
# HDMI hotplug 복구 (udev 70-hdmi-hotplug.rules가 DRM change 이벤트마다 실행)
#
# 커널(hdmitx21)은 플러그아웃 때 TMDS PHY를 끄지만 재연결 때 자동으로 다시
# 켜주지 않음(커널 소스 확인: hdmitx_plugin_common_work는 EDID만 다시 읽음).
# DRM atomic 상태(ES가 커밋한 plane/CRTC)는 플러그아웃에도 유지되므로,
# 같은 모니터 재연결은 PHY만 켜면 화면이 그대로 복구됨 - ES 재시작 불필요.
#
# 모니터가 "다른" 것으로 바뀐 경우(EDID 해시 불일치)는 이전 해상도가 새
# 모니터에서 안 나올 수 있으므로 ES를 종료시킴 - S99emulationstation의
# while 루프가 ES 종료를 감지하고 EDID 기반 해상도 재적용 후 ES를 재시작하는
# 기존 검증된 경로를 그대로 태우는 방식(이 스크립트가 직접 모드를 바꾸지
# 않는 이유: ES가 DRM master를 쥔 동안엔 외부 모드 변경이 거부됨).
#
# 기준선(/var/run/hdmi-edid.sha)은 S99emulationstation이 해상도 적용 직후에
# 기록함 - tmpfs라 부팅마다 리셋. 기준선이 없으면(부팅 직후 등) S99가 아직
# 해상도를 적용하기 전이므로 교체 판정 없이 PHY만 복구.
#
# 알려진 한계: 게임 실행 중 모니터를 교체하면 ES에 SIGTERM이 가면서 게임도
# 함께 종료됨(저장 안 된 진행 손실 가능) - 교체는 의도적 행위이고 화면이
# 아예 안 나오는 것보단 낫다고 판단. 조사 기록:
# docs/retropangui/todo-20260712-hdmi-hotplug-investigation.html
TAG="hdmi-hotplug"
HPD="/sys/devices/virtual/amhdmitx/amhdmitx0/hpd_state"
PHY="/sys/class/amhdmitx/amhdmitx0/phy"
EDID="/sys/class/drm/card0-HDMI-A-A/edid"
BASELINE="/var/run/hdmi-edid.sha"

[ -r "${HPD}" ] || exit 0

# 케이블 꽂은 직후 신호가 안정될 때까지 잠깐 대기 후 최종 상태로 판정
sleep 2
if [ "$(cat "${HPD}")" != "1" ]; then
    logger -t "${TAG}" "plugout event - nothing to do"
    exit 0
fi

# PHY 재활성화 (성공 여부는 dmesg의 phy_store/set21_phy 로그로 확인 가능 -
# 이 sysfs는 읽기 시 별도 레지스터를 반환해서 read-back 검증이 안 됨)
echo 1 > "${PHY}" 2>/dev/null || true
logger -t "${TAG}" "reconnect: PHY re-enabled"

# 모니터 교체 감지 - EDID 해시를 S99가 기록해둔 기준선과 비교
NEW_HASH="$(sha256sum "${EDID}" 2>/dev/null | cut -d' ' -f1)"
if [ -z "${NEW_HASH}" ]; then
    logger -t "${TAG}" "EDID unreadable - skip monitor-change check"
    exit 0
fi
OLD_HASH="$(cat "${BASELINE}" 2>/dev/null)"
if [ -z "${OLD_HASH}" ]; then
    logger -t "${TAG}" "no baseline yet (boot in progress?) - PHY only"
    exit 0
fi
if [ "${NEW_HASH}" = "${OLD_HASH}" ]; then
    logger -t "${TAG}" "same monitor - resolution kept"
    exit 0
fi

# 다른 모니터: 기준선을 먼저 갱신(이벤트 연발 시 중복 재시작 방지)하고
# ES를 종료 - S99 루프가 새 EDID로 해상도 재적용 + ES 재시작을 담당
echo "${NEW_HASH}" > "${BASELINE}"
logger -t "${TAG}" "monitor changed (EDID mismatch) - restarting ES for renegotiation"
if [ -f /tmp/es.pid ]; then
    kill "$(cat /tmp/es.pid 2>/dev/null)" 2>/dev/null || true
else
    logger -t "${TAG}" "ES not running - S99 loop will pick up new EDID on next start"
fi
