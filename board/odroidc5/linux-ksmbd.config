# ksmbd: 커널 내장 SMB3 서버
CONFIG_SMB_SERVER=m
CONFIG_SMB_SERVER_SMBDIRECT=n

# squashfs built-in (initramfs 단계에서 모듈 로드 불가)
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_XZ=y
CONFIG_SQUASHFS_ZSTD=y

# overlayfs built-in (initramfs에서 overlayfs 마운트)
CONFIG_OVERLAY_FS=y

# loop device built-in (squashfs를 loop으로 마운트)
CONFIG_BLK_DEV_LOOP=y

# devtmpfs: /dev 자동 생성
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=n

# 컨트롤러 입력
CONFIG_JOYSTICK_XPAD=m
CONFIG_JOYSTICK_XPAD_FF=y
CONFIG_JOYSTICK_XPAD_LEDS=y
CONFIG_INPUT_JOYDEV=y

# 2026-07-06: DS2(PS2 컨트롤러)→USB 컨버터("HID 0925:8866", 커널
# hid-ids.h에 USB_DEVICE_ID_DUAL_USB_JOYPAD로 정확히 등록돼 있음) 진동 안
# 되던 문제 - hid-generic이 이 장치의 벤더 정의 출력 리포트를 표준
# force-feedback으로 해석 못해서였음. 이 장치를 정확히 겨냥한 전용 드라이버
# (hid-sjoy.c, "SmartJoy PLUS PS2/USB adapter")가 이미 커널에 있고, FF도
# 지원함(input_ff_create_memless 기반) - 활성화하면 RetroArch의 기존
# input_joypad_driver=udev 설정 그대로 표준 EV_FF로 정상 작동할 것으로
# 기대했음.
#
# 2026-07-10: 실기기 실제 게임(Gran Turismo) 테스트 결과, 표준 드라이버
# 경로로도 진동이 트리거되는 시점에 패드 입력이 완전히 먹통됨(키 입력이
# 마지막 상태로 고정, 아무 버튼도 안 먹힘) - 예전 raw hidraw 실험 때 봤던
# "USB 연결이 반복적으로 끊기는 불안정함"과 같은 근본 원인으로 추정(이
# 값싼 클론 컨버터가 FF 출력 리포트 자체에 약한 것으로 보임, 소프트웨어
# 버그인지 하드웨어 한계인지는 다른 배포판 교차검증 필요 -
# todo-20260709-ps2-adapter-ff-freeze.html 참고). 게임 중 조작 불능은
# 진동 없는 것보다 훨씬 심각한 회귀라 FF만 우선 비활성화 - 입력은
# CONFIG_HID_SMARTJOYPLUS만으로 정상 작동하며 영향 없음. 원인이 명확히
# 밝혀지면(다른 배포판에서도 재현되면 하드웨어 한계로 확정, 재현 안 되면
# 이 프로젝트 쪽 문제로 좁혀 재조사) 재활성화 검토.
CONFIG_HID_SMARTJOYPLUS=y
# CONFIG_SMARTJOYPLUS_FF is not set

# 2026-07-07: "Twin USB Joystick"(0810:0001)도 같은 이유로 진동 안 됨 - 커널
# hid-ids.h 확인 결과 USB_VENDOR_ID_GAMERON/USB_VENDOR_ID_PANTHERLORD 둘 다
# 0x0810이고, USB_DEVICE_ID_GAMERON_DUAL_PSX_ADAPTOR(0x0001)와
# USB_DEVICE_ID_PANTHERLORD_TWIN_USB_JOYSTICK(0x0001)가 같은 수치값 -
# hid-pl.c 드라이버 자체 주석에도 "Twin USB Joystick"이라고 명시돼 있어 정확히
# 이 장치가 대상. input_ff_create_memless 기반 FF 지원.
CONFIG_HID_PANTHERLORD=y
CONFIG_PANTHERLORD_FF=y
