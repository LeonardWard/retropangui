# ksmbd: 커널 내장 SMB3 서버
CONFIG_SMB_SERVER=m
CONFIG_SMB_SERVER_SMBDIRECT=n

# squashfs built-in (initramfs 단계에서 모듈 로드 불가)
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_XZ=y
CONFIG_SQUASHFS_ZSTD=y

# overlayfs built-in (initramfs에서 overlayfs 마운트)
CONFIG_OVERLAY_FS=y

# loop device built-in (squashfs를 loop으로 마운트)
CONFIG_BLK_DEV_LOOP=y

# devtmpfs: /dev 자동 생성
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=n

# 컨트롤러 입력
CONFIG_JOYSTICK_XPAD=m
CONFIG_JOYSTICK_XPAD_FF=y
CONFIG_JOYSTICK_XPAD_LEDS=y
CONFIG_INPUT_JOYDEV=y

# 2026-07-06: DS2(PS2 컨트롤러)→USB 컨버터("HID 0925:8866", 커널
# hid-ids.h에 USB_DEVICE_ID_DUAL_USB_JOYPAD로 정확히 등록돼 있음) 진동 안
# 되던 문제 - hid-generic이 이 장치의 벤더 정의 출력 리포트를 표준
# force-feedback으로 해석 못해서였음. 이 장치를 정확히 겨냥한 전용 드라이버
# (hid-sjoy.c, "SmartJoy PLUS PS2/USB adapter")가 이미 커널에 있고, FF도
# 지원함(input_ff_create_memless 기반) - 활성화하면 RetroArch의 기존
# input_joypad_driver=udev 설정 그대로 표준 EV_FF로 정상 작동함.
CONFIG_HID_SMARTJOYPLUS=y
CONFIG_SMARTJOYPLUS_FF=y
