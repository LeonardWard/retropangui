# ksmbd: 커널 내장 SMB3 서버
CONFIG_SMB_SERVER=m
CONFIG_SMB_SERVER_SMBDIRECT=n

# squashfs built-in (initramfs 단계에서 모듈 로드 불가)
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_XZ=y
CONFIG_SQUASHFS_ZSTD=y

# overlayfs built-in (initramfs에서 overlayfs 마운트)
CONFIG_OVERLAY_FS=y

# loop device built-in (squashfs를 loop으로 마운트)
CONFIG_BLK_DEV_LOOP=y

# devtmpfs: /dev 자동 생성
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=n

# 컨트롤러 입력
CONFIG_JOYSTICK_XPAD=m
CONFIG_JOYSTICK_XPAD_FF=y
CONFIG_JOYSTICK_XPAD_LEDS=y
CONFIG_INPUT_JOYDEV=y
