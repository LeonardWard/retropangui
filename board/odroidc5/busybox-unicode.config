# 2026-07-08: 기본 busybox.config는 유니코드 지원이 꺼져있어서(CONFIG_UNICODE_SUPPORT
# not set, CONFIG_SUBST_WCHAR=0) ls 등 busybox 명령어가 ASCII 아닌 문자(한글 등)를
# 전부 "?"로 강제 치환함 - 실제 파일명/파일 내용은 항상 정상이었고 화면 표시만
# 깨졌던 것으로 실기기에서 확인(Python os.listdir()로는 정상 출력됨). glibc 쪽
# ko_KR.UTF-8 로케일 자체는 정상(wcwidth()로 한글 확인됨)이라 UNICODE_USING_LOCALE로
# glibc에 위임하도록 설정.
CONFIG_LOCALE_SUPPORT=y
CONFIG_UNICODE_SUPPORT=y
CONFIG_UNICODE_USING_LOCALE=y
CONFIG_FEATURE_CHECK_UNICODE_IN_ENV=y
CONFIG_UNICODE_WIDE_WCHARS=y
